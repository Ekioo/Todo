@using KittyClaw.Core.Automation
@using KittyClaw.Web.Services
@using Markdig
@inject AgentRunsState RunsState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LocalizationService L
@implements IAsyncDisposable

<div class="chat-drawer-overlay" @onclick="Close"></div>
<div class="chat-drawer" @onclick:stopPropagation>
    @if (_view == View.Selection)
    {
        <div class="chat-drawer-header">
            <span class="chat-drawer-title">@L["NewInstruction"]</span>
            <button class="agent-close-btn" @onclick="Close" title="@L["Close"]">×</button>
        </div>
        <div class="chat-target-list">
            <h3>@L["ChatPickTarget"]</h3>
            @foreach (var t in _targets)
            {
                <button class="chat-target-item @(t.Kind == "claude" ? "claude-direct" : "")"
                        @onclick="() => SelectTarget(t)">
                    <span class="chat-target-name">@t.Name</span>
                    <span class="chat-target-kind">@(t.Kind == "claude" ? L["ChatTalkToClaude"] : L["ChatMember"])</span>
                </button>
            }
            @if (_targets.Count == 0 && _ready)
            {
                <div class="chat-empty">@L["ChatPickTarget"]</div>
            }
        </div>
    }
    else
    {
        <div class="chat-drawer-header">
            @if (TicketId is null)
            {
                <button class="chat-back-btn" @onclick="BackToSelection" title="@L["Back"]">‹</button>
            }
            <span class="chat-drawer-title">
                @_activeTarget!.Name
                @if (TicketId is int tid)
                {
                    <span class="chat-drawer-ticket-ref" title="@TicketTitle">· #@tid @(string.IsNullOrEmpty(TicketTitle) ? "" : "— " + Truncate(TicketTitle!, 40))</span>
                }
            </span>
            <button class="chat-newsession-btn" @onclick="StartNewSession" title="@L["NewSession"]">＋</button>
            <button class="agent-close-btn" @onclick="Close" title="@L["Close"]">×</button>
        </div>

        <div class="chat-messages" @ref="_messagesRef">
            @foreach (var msg in _messages)
            {
                if (msg.Role == "tool_use")
                {
                    var toolMsg = (ToolCallMessage)msg;
                    <div class="chat-message chat-message-tool">
                        <details class="tool-call-block">
                            <summary class="tool-call-summary">
                                <span class="tool-call-icon">⚙</span>
                                <span class="tool-call-name">@toolMsg.ToolName</span>
                                <span class="tool-call-preview">@toolMsg.Preview</span>
                            </summary>
                            <pre class="tool-call-detail">@toolMsg.Detail</pre>
                        </details>
                    </div>
                }
                else if (msg.Role == "reset")
                {
                    <div class="chat-message chat-message-reset">@L["ChatSessionReset"]</div>
                }
                else
                {
                    <div class="chat-message chat-message-@msg.Role">
                        <div class="chat-bubble markdown-body">@((MarkupString)RenderMarkdown(msg.Text))</div>
                    </div>
                }
            }
            @if (_loading)
            {
                <div class="chat-message chat-message-assistant">
                    <div class="chat-bubble chat-bubble-loading">…</div>
                </div>
            }
            @if (_messages.Count == 0 && !_loading)
            {
                <div class="chat-empty">
                    @(_activeTarget!.Kind == "member"
                        ? L.Get("ChatEmptyMember", _activeTarget.Name)
                        : L["ChatEmpty"])
                </div>
            }
        </div>

        <div class="chat-input-area">
            <textarea @ref="_inputRef"
                      value="@_inputText"
                      @oninput="OnInput"
                      placeholder="@L["ChatPlaceholder"]"
                      @onkeydown="OnKeyDown"
                      disabled="@_loading"></textarea>
            <button @onclick="Send" disabled="@(string.IsNullOrWhiteSpace(_inputText) || _loading)">@L["Send"]</button>
        </div>
    }
</div>

@code {
    [Parameter] public string ProjectSlug { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Optional. When set, skip the target picker and start a chat with this agent slug.</summary>
    [Parameter] public string? InitialAgent { get; set; }
    /// <summary>Optional. Display name for the InitialAgent (falls back to slug).</summary>
    [Parameter] public string? InitialAgentName { get; set; }
    /// <summary>Optional. When set together with InitialAgent, scopes the chat to a specific ticket.</summary>
    [Parameter] public int? TicketId { get; set; }
    /// <summary>Optional. Title of the scoped ticket, shown in the drawer header.</summary>
    [Parameter] public string? TicketTitle { get; set; }

    private enum View { Selection, Conversation }
    private View _view = View.Selection;

    private readonly List<ChatTarget> _targets = [];
    private ChatTarget? _activeTarget;
    private bool _ready = false;

    private readonly List<ChatMessage> _messages = [];
    private string _inputText = "";
    private bool _loading = false;
    private ElementReference _messagesRef;
    private ElementReference _inputRef;
    private AgentRun? _activeRun;
    private IJSObjectReference? _sseModule;
    private DotNetObjectReference<ClaudeChatDrawer>? _dotnetRef;
    private string? _activeStreamId;

    private record ChatMessage(string Role, string Text);
    private sealed record ToolCallMessage(string ToolName, string Preview, string Detail)
        : ChatMessage("tool_use", ToolName);
    private sealed record ChatTarget(string Slug, string Name, string Kind);

    protected override async Task OnInitializedAsync()
    {
        // Ticket-scoped or pre-targeted chat: skip the picker entirely.
        if (!string.IsNullOrWhiteSpace(InitialAgent))
        {
            var slug = TicketId is int id ? $"{InitialAgent}#ticket-{id}" : InitialAgent!;
            var name = string.IsNullOrWhiteSpace(InitialAgentName) ? InitialAgent! : InitialAgentName!;
            var target = new ChatTarget(slug, name, "member");
            await EnterConversationAsync(target);
            _ready = true;
            return;
        }

        using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
        try
        {
            var resp = await http.GetFromJsonAsync<TargetsResponse>($"/api/projects/{ProjectSlug}/chat/targets");
            if (resp is not null)
            {
                _targets.Clear();
                foreach (var t in resp.Targets)
                    _targets.Add(new ChatTarget(t.Slug, t.Name, t.Kind));

                if (!string.IsNullOrEmpty(resp.LastTarget))
                {
                    var last = _targets.FirstOrDefault(t => t.Slug == resp.LastTarget);
                    if (last is not null)
                    {
                        await EnterConversationAsync(last);
                    }
                }
            }
        }
        catch { /* leave _view = Selection */ }
        finally { _ready = true; }
    }

    private async Task EnterConversationAsync(ChatTarget target)
    {
        _activeTarget = target;
        _messages.Clear();
        string? latestMessageAt = null;
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var msgs = await http.GetFromJsonAsync<List<ServerChatMessage>>(
                $"/api/projects/{ProjectSlug}/chat/messages?target={Uri.EscapeDataString(target.Slug)}");
            if (msgs is not null)
            {
                foreach (var m in msgs)
                {
                    if (m.Role == "tool_use")
                    {
                        var preview = GetToolPreview(m.ToolName ?? m.Text, m.Detail);
                        _messages.Add(new ToolCallMessage(m.ToolName ?? m.Text, preview, m.Detail ?? "{}"));
                    }
                    else
                    {
                        _messages.Add(new ChatMessage(m.Role, m.Text));
                    }
                    latestMessageAt = m.CreatedAt;
                }
            }
        }
        catch { /* show empty conversation */ }
        _view = View.Conversation;
        StateHasChanged();

        // If a chat run is still in flight server-side (drawer was closed mid-stream
        // and the backend kept emitting events), reattach the SSE stream so the
        // remaining and future events surface in the UI. The `since` cursor avoids
        // replaying buffered events already persisted before this reopen.
        await TryReattachActiveRunAsync(target, latestMessageAt);
    }

    private async Task TryReattachActiveRunAsync(ChatTarget target, string? sinceIso)
    {
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            var resp = await http.GetFromJsonAsync<ActiveResponse>(
                $"/api/projects/{ProjectSlug}/chat/active?target={Uri.EscapeDataString(target.Slug)}");
            if (resp?.RunId is not string runId) return;

            _activeRun = RunsState.Get(runId);
            _loading = true;
            _sseModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/agent-sse.js");
            _dotnetRef ??= DotNetObjectReference.Create(this);
            _activeStreamId = runId;
            var url = $"/api/projects/{ProjectSlug}/runs/{runId}/stream";
            if (!string.IsNullOrEmpty(sinceIso))
                url += $"?since={Uri.EscapeDataString(sinceIso)}";
            await _sseModule.InvokeVoidAsync("start", _dotnetRef, url);
            StateHasChanged();
        }
        catch { /* best-effort */ }
    }

    private async Task SelectTarget(ChatTarget t)
    {
        // When the drawer is ticket-scoped but no agent was preselected, re-key the
        // chosen target into the per-ticket composite slug so this conversation
        // gets its own thread.
        if (TicketId is int id && !t.Slug.Contains('#'))
        {
            t = t with { Slug = $"{t.Slug}#ticket-{id}" };
        }
        await EnterConversationAsync(t);
    }

    private async Task BackToSelection()
    {
        await StopStream();
        _view = View.Selection;
        _activeTarget = null;
        _messages.Clear();
        _loading = false;
        StateHasChanged();
    }

    private async Task StartNewSession()
    {
        if (_activeTarget is null) return;
        await StopStream();
        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
            await http.DeleteAsync($"/api/projects/{ProjectSlug}/chat/session?target={Uri.EscapeDataString(_activeTarget.Slug)}");
        }
        catch { /* best-effort */ }
        _messages.Clear();
        _loading = false;
        // Ticket-scoped chats stay on the same target after a reset; only the picker mode falls back to selection.
        if (string.IsNullOrWhiteSpace(InitialAgent))
        {
            _view = View.Selection;
            _activeTarget = null;
        }
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await _inputRef.FocusAsync(); } catch { }
        }
        if (_view == View.Conversation)
        {
            try { await JS.InvokeVoidAsync("chatDrawerInstallEnterGuard", _inputRef); } catch { }
        }
        try
        {
            await JS.InvokeVoidAsync("chatDrawerScrollToBottom", _messagesRef);
        }
        catch { }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await Send();
    }

    private void OnInput(ChangeEventArgs e)
    {
        _inputText = e.Value?.ToString() ?? "";
    }

    private async Task Send()
    {
        var text = _inputText.Trim();
        if (string.IsNullOrEmpty(text) || _loading || _activeTarget is null) return;

        _messages.Add(new ChatMessage("user", text));
        _inputText = "";
        _loading = true;
        StateHasChanged();

        await StopStream();

        using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
        try
        {
            var resp = await http.PostAsJsonAsync($"/api/projects/{ProjectSlug}/chat/start",
                new { message = text, target = _activeTarget.Slug, ticketId = TicketId });
            if (!resp.IsSuccessStatusCode)
            {
                _messages.Add(new ChatMessage("error", $"Error {resp.StatusCode}"));
                _loading = false;
                StateHasChanged();
                return;
            }
            var body = await resp.Content.ReadFromJsonAsync<ChatStartResponse>();
            if (body is null) { _loading = false; StateHasChanged(); return; }

            _activeRun = RunsState.Get(body.RunId);
            if (_activeRun is not null)
            {
                _activeRun.OnEvent += HandleEvent;
                _sseModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/agent-sse.js");
                _dotnetRef ??= DotNetObjectReference.Create(this);
                _activeStreamId = body.RunId;
                await _sseModule.InvokeVoidAsync("start", _dotnetRef, $"/api/projects/{ProjectSlug}/runs/{body.RunId}/stream");
            }
            else
            {
                _messages.Add(new ChatMessage("error", "Run not found"));
                _loading = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage("error", ex.Message));
            _loading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task ReceiveSse(string kind, string text, string? detail = null)
    {
        if (kind == "tool_use" && !string.IsNullOrWhiteSpace(text))
        {
            var preview = GetToolPreview(text, detail);
            _messages.Add(new ToolCallMessage(text, preview, detail ?? "{}"));
        }
        else if (kind == "reset")
        {
            _messages.Add(new ChatMessage("reset", text));
        }
        else if (kind == "assistant")
        {
            // FlattenJson produces "[assistant] <response text>" for assistant turn events
            // Skip if it only contains tool: references (those are emitted as separate tool_use events)
            const string prefix = "[assistant] ";
            var reply = text.StartsWith(prefix) ? text[prefix.Length..] : text;
            reply = reply.Trim();
            if (!string.IsNullOrWhiteSpace(reply) && !reply.StartsWith("tool:"))
                _messages.Add(new ChatMessage("assistant", reply));
        }
        return InvokeAsync(StateHasChanged);
    }

    private static string GetToolPreview(string toolName, string? detail)
    {
        if (string.IsNullOrWhiteSpace(detail) || detail == "{}") return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detail);
            var root = doc.RootElement;
            return toolName switch
            {
                "Bash" => Truncate(root.TryGetProperty("command", out var c) ? c.GetString() : null),
                "Read" => Truncate(root.TryGetProperty("file_path", out var fp) ? fp.GetString() : null),
                "Write" => Truncate(root.TryGetProperty("file_path", out var fp2) ? fp2.GetString() : null),
                "Edit" => Truncate(root.TryGetProperty("file_path", out var fp3) ? fp3.GetString() : null),
                "Glob" => Truncate(root.TryGetProperty("pattern", out var p) ? p.GetString() : null),
                "Grep" => Truncate(root.TryGetProperty("pattern", out var gp) ? gp.GetString() : null),
                "WebFetch" or "WebSearch" => Truncate(root.TryGetProperty("url", out var u) ? u.GetString()
                    : root.TryGetProperty("query", out var q) ? q.GetString() : null),
                _ => Truncate(root.EnumerateObject().FirstOrDefault().Value.GetString())
            };
        }
        catch { return ""; }
    }

    private static string Truncate(string? s, int max = 80) =>
        s is null ? "" : s.Length <= max ? s : s[..max] + "…";

    [JSInvokable]
    public Task StreamEnded()
    {
        _loading = false;
        if (_activeRun is not null)
            _activeRun.OnEvent -= HandleEvent;
        _activeRun = null;
        _activeStreamId = null;
        return InvokeAsync(StateHasChanged);
    }

    private void HandleEvent(StreamEvent ev)
    {
        // Handled via SSE; no-op here to avoid duplicates
    }

    private async Task StopStream()
    {
        if (_sseModule is not null && _activeStreamId is not null)
        {
            try { await _sseModule.InvokeVoidAsync("stop"); } catch { }
        }
        if (_activeRun is not null)
            _activeRun.OnEvent -= HandleEvent;
        _activeRun = null;
        _activeStreamId = null;
    }

    private async Task Close()
    {
        await StopStream();
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        await StopStream();
        _dotnetRef?.Dispose();
        if (_sseModule is not null)
        {
            try { await _sseModule.DisposeAsync(); } catch { }
        }
    }

    private static string RenderMarkdown(string text) =>
        Markdig.Markdown.ToHtml(text, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());

    private sealed record ChatStartResponse(string RunId);
    private sealed record ActiveResponse(string? RunId);
    private sealed record TargetsResponse(string? LastTarget, List<ServerChatTarget> Targets);
    private sealed record ServerChatTarget(string Slug, string Name, string Kind);
    private sealed record ServerChatMessage(string Role, string Text, string? ToolName, string? Detail, string CreatedAt);
}
