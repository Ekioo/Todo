@page "/"
@using KittyClaw.Core.Models
@using KittyClaw.Core.Services
@using KittyClaw.Core.Automation
@inject ProjectService ProjectService
@inject AgentsTemplateService AgentsTemplate
@inject AutomationEngine AutomationEngine
@inject MemberService MemberService
@inject AppSettingsService AppSettings
@inject LocalizationService L
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject KittyClaw.Web.Services.EscapeKeyStack EscapeStack
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>@L["HomeTitle"]</PageTitle>

@if (!_showOnboarding)
{
<div class="page-header home-header">
    <img src="/KittyClaw-Logo-Horizontal.webp" alt="KittyClaw" class="home-logo-horizontal" />
</div>

<div class="project-list" @oncontextmenu="ShowSortMenu" @oncontextmenu:preventDefault>
    @if (_projects is not null)
    {
        @foreach (var project in SortedProjects)
        {
            <div class="project-card-wrap @(project.IsPaused ? "project-paused" : "")">
                <a class="project-card" href="/board/@project.Slug">
                    <h3>
                        @project.Name
                        @if (project.IsPaused)
                        {
                            <span class="project-paused-badge">⏸ @L["Paused"]</span>
                        }
                    </h3>
                    <small>@project.Slug</small>
                </a>
                <button class="project-pause-btn" title="@(project.IsPaused ? L["Resume"] : L["Pause"])"
                        @onclick="() => TogglePause(project)" @onclick:stopPropagation>
                    @(project.IsPaused ? "▶" : "⏸")
                </button>
                <button class="project-delete-btn" title="@L["Delete"]" @onclick="() => AskDelete(project)">&times;</button>
            </div>
        }
    }
</div>

@if (_sortMenuVisible)
{
    <div class="context-menu-backdrop" @onclick="HideSortMenu"></div>
    <div class="context-menu" style="left:@(_sortMenuX)px;top:@(_sortMenuY)px">
        <button class="context-menu-item @(_sortOrder == "name" ? "active" : "")" @onclick='() => SetSort("name")'>
            @if (_sortOrder == "name") { <span class="context-menu-check">✓</span> } else { <span class="context-menu-check"></span> }
            @L["SortByName"]
        </button>
        <button class="context-menu-item @(_sortOrder == "created" ? "active" : "")" @onclick='() => SetSort("created")'>
            @if (_sortOrder == "created") { <span class="context-menu-check">✓</span> } else { <span class="context-menu-check"></span> }
            @L["SortByCreationDate"]
        </button>
        <button class="context-menu-item @(_sortOrder == "updated" ? "active" : "")" @onclick='() => SetSort("updated")'>
            @if (_sortOrder == "updated") { <span class="context-menu-check">✓</span> } else { <span class="context-menu-check"></span> }
            @L["SortByLastModified"]
        </button>
    </div>
}

<div class="create-project">
    <input @bind="_newProjectName" @bind:event="oninput" placeholder="@L["NewProjectPlaceholder"]"
           @onkeydown="HandleKeyDown" />
    <button @onclick="CreateProject" disabled="@string.IsNullOrWhiteSpace(_newProjectName)">@L["Create"]</button>
</div>
}

@if (_deleteTarget is not null)
{
    <div class="confirm-overlay" @onclick="CancelDelete">
        <div class="confirm-dialog" @onclick:stopPropagation>
            <p>@L["DeleteProjectConfirm"] <strong>@_deleteTarget.Name</strong>&#160;?</p>
            <p class="confirm-warning">@L["DeleteProjectWarning"]</p>
            <div class="confirm-actions">
                <button class="cancel-btn" @onclick="CancelDelete">@L["Cancel"]</button>
                <button class="delete-btn" @onclick="ConfirmDelete">@L["Delete"]</button>
            </div>
        </div>
    </div>
}

@if (_showOnboarding)
{
    <div class="modal-backdrop">
        <div class="modal-dialog onboarding-dialog" @onclick:stopPropagation>
            <img src="/KittyClaw.webp" alt="KittyClaw" class="onboarding-logo" />
            <h2>@L["OnboardingTitle"]</h2>
            <p>@L["OnboardingIntro1"]</p>
            <p>@L["OnboardingIntro2"]</p>

            <h3 style="margin-top:1rem;font-size:0.95rem">@L["OnboardingRequirements"]</h3>
            <div class="onboarding-check @(_claudeInstalled ? "ok" : "missing")">
                <span>@(_claudeInstalled ? "✓" : "✗") Claude Code</span>
                @if (!_claudeInstalled)
                {
                    <a class="header-action-btn" href="https://docs.claude.com/en/docs/claude-code/overview" target="_blank" rel="noopener">@L["OnboardingInstall"]</a>
                }
            </div>
            <div class="onboarding-check @(_gitInstalled ? "ok" : "missing")">
                <span>@(_gitInstalled ? "✓" : "✗") Git</span>
                @if (!_gitInstalled)
                {
                    <a class="header-action-btn" href="https://git-scm.com/downloads" target="_blank" rel="noopener">@L["OnboardingInstall"]</a>
                }
            </div>

            @if (!_claudeInstalled || !_gitInstalled)
            {
                <p class="settings-status settings-status-err" style="margin-top:0.75rem">@L["OnboardingMissingWarning"]</p>
            }

            <div class="modal-actions">
                <button class="header-action-btn" @onclick="RecheckTools">@L["Recheck"]</button>
                <button class="header-action-btn settings-primary" @onclick="DismissOnboarding">@L["Continue"]</button>
            </div>
        </div>
    </div>
}

@if (_pendingName is not null)
{
    <div class="modal-backdrop">
        <div class="modal-dialog" @onclick:stopPropagation>
            <h2>@_pendingName</h2>
            <p>@L["CreationSetupIntro"]</p>

            <label class="settings-label">@L["WorkspacePath"] *</label>
            <p class="settings-hint">@L["WorkspaceHint"]</p>
            <div class="settings-row">
                <input class="settings-input" placeholder="@L["WorkspacePlaceholder"]" @bind="_newWorkspacePath" @bind:event="oninput" @bind:after="OnWorkspaceChanged" />
                @if (_canBrowse)
                {
                    <button class="settings-browse" @onclick="BrowseWorkspace" disabled="@_browsing">
                        @(_browsing ? "…" : $"📁 {L["Browse"]}")
                    </button>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_newWorkspacePath) && _workspaceExists == false)
            {
                <div class="settings-status settings-status-err">
                    <span>@L["WorkspaceMissing"]</span>
                    <button class="header-action-btn" @onclick="CreateWorkspaceFolder" disabled="@_creatingFolder" style="margin-left:0.75rem">
                        @(_creatingFolder ? "…" : L["CreateFolder"])
                    </button>
                </div>
            }

            @if (_creationStatus is not null)
            {
                <div class="settings-status @_creationStatus.Value.css">@_creationStatus.Value.text</div>
            }

            @if (_initConflicts is not null)
            {
                <div class="init-conflict-block">
                    <p><strong>@L["InitializeConfirmTitle"]</strong></p>
                    <p>@L["InitializeConfirmIntro"]</p>
                    <ul class="init-conflict-list">
                        @foreach (var f in _initConflicts)
                        {
                            <li><code>@f</code></li>
                        }
                    </ul>
                    <div class="modal-actions">
                        <button class="header-action-btn" @onclick="() => _initConflicts = null">@L["Cancel"]</button>
                        <button class="header-action-btn" @onclick="() => CreateAndInitialize(false)">@L["InitializeSkip"]</button>
                        <button class="header-action-btn settings-primary" @onclick="() => CreateAndInitialize(true)">@L["InitializeOverwrite"]</button>
                    </div>
                </div>
            }

            <div class="modal-actions">
                <button class="header-action-btn" @onclick="CancelCreation" disabled="@_initializing">@L["Cancel"]</button>
                <button class="header-action-btn settings-primary" @onclick="StartInitialize" disabled="@(_initializing || _initConflicts is not null || string.IsNullOrWhiteSpace(_newWorkspacePath) || _workspaceExists != true)">
                    @(_initializing ? "…" : L["Initialize"])
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Project>? _projects;
    private string _newProjectName = "";
    private string _sortOrder = "name";
    private bool _sortMenuVisible;
    private double _sortMenuX, _sortMenuY;

    private IEnumerable<Project> SortedProjects => (_projects ?? []).OrderBy(SortKey).ThenBy(p => p.Name);

    private IComparable SortKey(Project p) => _sortOrder switch
    {
        "created" => p.CreatedAt,
        "updated" => p.UpdatedAt,
        _ => (IComparable)p.Name
    };
    private Project? _deleteTarget;

    private string? _pendingName;
    private string _newWorkspacePath = "";
    private bool _browsing, _canBrowse;
    private bool _initializing;
    private bool _creatingFolder;
    private bool? _workspaceExists;
    private bool _showOnboarding;
    private bool _onboardingEvaluated;
    private bool _claudeInstalled;
    private bool _gitInstalled;
    private List<string>? _initConflicts;
    private (string text, string css)? _creationStatus;
    private IDisposable? _escOnboarding;
    private IDisposable? _escPending;
    private IDisposable? _escDelete;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLangChanged;
        RecheckTools();
        _showOnboarding = !AppSettings.OnboardingSeen || !_claudeInstalled || !_gitInstalled;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_onboardingEvaluated)
        {
            _onboardingEvaluated = true;
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "kc-project-sort");
            if (stored is "name" or "created" or "updated") _sortOrder = stored;
            if (!_showOnboarding)
            {
                await LoadProjectsAsync();
            }
        }
        SyncEscapeTokens();
    }

    private void SyncEscapeTokens()
    {
        if (_showOnboarding && _escOnboarding is null)
            _escOnboarding = EscapeStack.PushWithFocus(JS, () => InvokeAsync(async () => { await DismissOnboarding(); }));
        else if (!_showOnboarding && _escOnboarding is not null)
        { _escOnboarding.Dispose(); _escOnboarding = null; }

        if (_pendingName is not null && _escPending is null)
            _escPending = EscapeStack.PushWithFocus(JS, () => InvokeAsync(() => { CancelCreation(); StateHasChanged(); }));
        else if (_pendingName is null && _escPending is not null)
        { _escPending.Dispose(); _escPending = null; }

        if (_deleteTarget is not null && _escDelete is null)
            _escDelete = EscapeStack.PushWithFocus(JS, () => InvokeAsync(() => { CancelDelete(); StateHasChanged(); }));
        else if (_deleteTarget is null && _escDelete is not null)
        { _escDelete.Dispose(); _escDelete = null; }
    }

    private async Task LoadProjectsAsync()
    {
        _projects = await ProjectService.ListProjectsAsync();
        await ProbeBrowseAsync();
        StateHasChanged();
    }

    private void RecheckTools()
    {
        _claudeInstalled = AgentsTemplate.IsClaudeAvailable();
        _gitInstalled = AgentsTemplate.IsGitAvailable();
    }

    private async Task DismissOnboarding()
    {
        AppSettings.OnboardingSeen = true;
        _showOnboarding = false;
        await LoadProjectsAsync();
    }

    private HttpClient NewHttp()
    {
        var h = HttpFactory.CreateClient();
        h.BaseAddress = new Uri(Nav.BaseUri);
        return h;
    }

    private async Task ProbeBrowseAsync()
    {
        try
        {
            var caps = await NewHttp().GetFromJsonAsync<BrowseCapabilities>("/api/browse/capabilities");
            _canBrowse = caps?.FolderPicker == true;
        }
        catch { _canBrowse = false; }
    }

    private sealed record BrowseCapabilities(bool FolderPicker);
    private sealed record BrowseResult(string Path);

    private void CreateProject()
    {
        if (string.IsNullOrWhiteSpace(_newProjectName)) return;
        _pendingName = _newProjectName.Trim();
        _newWorkspacePath = "";
        _workspaceExists = null;
        _creationStatus = null;
        _initConflicts = null;
    }

    private void OnWorkspaceChanged()
    {
        var path = _newWorkspacePath?.Trim();
        _workspaceExists = string.IsNullOrEmpty(path) ? (bool?)null : Directory.Exists(path);
    }

    private void CreateWorkspaceFolder()
    {
        if (string.IsNullOrWhiteSpace(_newWorkspacePath)) return;
        _creatingFolder = true;
        _creationStatus = null;
        try
        {
            Directory.CreateDirectory(_newWorkspacePath.Trim());
            _workspaceExists = true;
            _creationStatus = (L["FolderCreated"], "settings-status-ok");
        }
        catch (Exception ex)
        {
            _creationStatus = ($"{L["Error"]}: {ex.Message}", "settings-status-err");
        }
        finally { _creatingFolder = false; }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") CreateProject();
    }

    private async Task BrowseWorkspace()
    {
        _browsing = true;
        try
        {
            var resp = await NewHttp().PostAsJsonAsync("/api/browse/folder", new { initialPath = _newWorkspacePath });
            if (resp.StatusCode == System.Net.HttpStatusCode.OK)
            {
                var body = await resp.Content.ReadFromJsonAsync<BrowseResult>();
                if (body?.Path is not null)
                {
                    _newWorkspacePath = body.Path;
                    OnWorkspaceChanged();
                }
            }
        }
        finally { _browsing = false; }
    }

    private async Task StartInitialize()
    {
        if (_pendingName is null || _initializing) return;
        _initializing = true;
        _creationStatus = null;
        try
        {
            var workspace = _newWorkspacePath.Trim();
            if (!AgentsTemplate.IsGitAvailable())
            {
                _creationStatus = (L["GitMissingWarning"], "settings-status-err");
            }
            var conflicts = AgentsTemplate.DetectConflicts(workspace);
            if (conflicts.Count == 0)
            {
                await CreateAndInitialize(false);
            }
            else
            {
                _initConflicts = conflicts;
            }
        }
        finally { _initializing = false; }
    }

    private async Task CreateAndInitialize(bool overwrite)
    {
        if (_pendingName is null) return;
        _initConflicts = null;
        _initializing = true;
        try
        {
            var project = await ProjectService.CreateProjectAsync(_pendingName);
            await ProjectService.UpdateProjectAsync(project.Slug, _newWorkspacePath.Trim());
            _newProjectName = "";
            _projects = await ProjectService.ListProjectsAsync();

            await AgentsTemplate.InitializeAsync(_newWorkspacePath.Trim(), overwrite);
            await EnsureAgentMembersAsync(project.Slug);
            await AutomationEngine.ReloadProjectAsync(project.Slug);

            _pendingName = null;
            Nav.NavigateTo($"/board/{project.Slug}");
        }
        catch (Exception ex)
        {
            _creationStatus = ($"{L["Error"]}: {ex.Message}", "settings-status-err");
        }
        finally { _initializing = false; }
    }

    private void CancelCreation()
    {
        _pendingName = null;
        _initConflicts = null;
        _creationStatus = null;
    }

    private async Task EnsureAgentMembersAsync(string projectSlug)
    {
        foreach (var slug in AgentsTemplate.AgentSlugs())
        {
            if (!await MemberService.MemberExistsAsync(projectSlug, slug))
                await MemberService.CreateMemberAsync(projectSlug, slug);
        }
    }

    private async Task TogglePause(Project project)
    {
        var updated = await ProjectService.TogglePauseAsync(project.Slug);
        if (updated is not null)
        {
            var idx = _projects!.IndexOf(project);
            if (idx >= 0) _projects[idx] = updated;
        }
    }

    private void AskDelete(Project project) => _deleteTarget = project;
    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        await ProjectService.DeleteProjectAsync(_deleteTarget.Slug);
        _deleteTarget = null;
        _projects = await ProjectService.ListProjectsAsync();
    }

    private void ShowSortMenu(MouseEventArgs e)
    {
        _sortMenuX = e.ClientX;
        _sortMenuY = e.ClientY;
        _sortMenuVisible = true;
    }

    private void HideSortMenu() => _sortMenuVisible = false;

    private async Task SetSort(string order)
    {
        _sortOrder = order;
        _sortMenuVisible = false;
        await JS.InvokeVoidAsync("localStorage.setItem", "kc-project-sort", order);
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose()
    {
        L.OnLanguageChanged -= OnLangChanged;
        _escOnboarding?.Dispose();
        _escPending?.Dispose();
        _escDelete?.Dispose();
    }
}
