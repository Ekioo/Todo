@using KittyClaw.Core.Automation
@using KittyClaw.Web.Services
@using Markdig
@inject AgentRunsState RunsState
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject LocalizationService L
@implements IAsyncDisposable

@if (_run is not null)
{
    <div class="agent-drawer-overlay" @onclick="Close"></div>
    <div class="agent-drawer" @onclick:stopPropagation>
        <div class="agent-drawer-header">
            <div class="agent-drawer-title">
                <span class="agent-name">@_run.AgentName</span>
                @if (_run.TicketId is not null)
                {
                    <span class="agent-ticket">#@_run.TicketId</span>
                }
                <span class="agent-status agent-status-@_run.Status.ToString().ToLowerInvariant()">@_run.Status</span>
            </div>
            <div class="agent-drawer-meta">
                <span title="Skill">@_run.SkillFile</span>
                <span title="Session">@(_run.SessionId?[..8] ?? "—")</span>
                <span title="Group">@_run.ConcurrencyGroup</span>
                <span>@FormatElapsed(_run.StartedAt)</span>
            </div>
            <div class="agent-drawer-actions">
                @if (_run.Status == AgentRunStatus.Running)
                {
                    <button class="agent-stop-btn" @onclick="Stop" title="@L["StopAgent"]">⏹ @L["Stop"]</button>
                }
                <button class="agent-close-btn" @onclick="Close" title="@L["Close"]">×</button>
            </div>
        </div>

        <div class="agent-drawer-console" @ref="_consoleRef">
            @foreach (var ev in _events)
            {
                @if (ev.Kind == "tool_use")
                {
                    <div class="console-line console-tool_use">
                        <span class="console-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                        <details class="console-tool-block">
                            <summary class="console-tool-summary">
                                <span class="console-tool-icon">⚙</span>
                                <span class="console-tool-name">@ev.Text</span>
                                <span class="console-tool-preview">@GetToolPreview(ev.Text, ev.Detail)</span>
                            </summary>
                            <pre class="console-tool-detail">@((MarkupString)HighlightJson(ev.Detail))</pre>
                        </details>
                    </div>
                }
                else if (ev.Kind == "rate_limit_event")
                {
                    <div class="console-line console-tool_use">
                        <span class="console-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                        <details class="console-tool-block console-rate-limit-block">
                            <summary class="console-tool-summary">
                                <span class="console-tool-icon">⏳</span>
                                <span class="console-tool-name">rate_limit_event</span>
                                <span class="console-tool-preview">@GetRateLimitPreview(ev.Text)</span>
                            </summary>
                            <pre class="console-tool-detail">@((MarkupString)HighlightJson(ev.Text))</pre>
                        </details>
                    </div>
                }
                else if (ev.Kind == "result")
                {
                    <div class="console-line console-tool_use">
                        <span class="console-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                        <details class="console-tool-block console-result-block">
                            <summary class="console-tool-summary">
                                <span class="console-tool-icon">✓</span>
                                <span class="console-tool-name">result</span>
                                <span class="console-tool-preview">@GetResultPreview(ev.Text)</span>
                            </summary>
                            <pre class="console-tool-detail">@((MarkupString)HighlightJson(ev.Text))</pre>
                        </details>
                    </div>
                }
                else if (ev.Kind is "user" or "assistant" or "system")
                {
                    var msgBody = GetMessageBody(ev.Text);
                    if (!string.IsNullOrWhiteSpace(msgBody))
                    {
                        var isShortMsg = msgBody.Length <= 300;
                        var msgPreview = Truncate(msgBody, 200);
                        <div class="console-line console-@ev.Kind">
                            <span class="console-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                            <details class="console-msg-block" open="@(isShortMsg ? "open" : null)">
                                <summary class="console-msg-summary">
                                    <span class="console-msg-role console-msg-role-@ev.Kind">@ev.Kind</span>
                                    @if (!isShortMsg)
                                    {
                                        <span class="console-msg-preview">@msgPreview</span>
                                    }
                                </summary>
                                @if (IsJson(msgBody))
                                {
                                    <pre class="console-tool-detail console-msg-json">@((MarkupString)HighlightJson(msgBody))</pre>
                                }
                                else
                                {
                                    <div class="console-msg-detail markdown">@((MarkupString)RenderMarkdown(msgBody))</div>
                                }
                            </details>
                        </div>
                    }
                }
                else
                {
                    var (tag, body) = ParseBracketTag(ev.Text);
                    <div class="console-line console-@ev.Kind">
                        <span class="console-time">@ev.At.ToLocalTime().ToString("HH:mm:ss")</span>
                        @if (tag is not null)
                        {
                            <span class="console-tag">@tag</span>
                        }
                        else
                        {
                            <span class="console-kind">@ev.Kind</span>
                        }
                        <span class="console-text markdown">@((MarkupString)RenderMarkdown(body))</span>
                    </div>
                }
            }
            @if (_events.Count == 0)
            {
                <div class="console-empty">@L["WaitingForOutput"]</div>
            }
        </div>

        @if (_run.Status == AgentRunStatus.Running)
        {
            <div class="agent-drawer-steer">
                <textarea @bind="_steerText" @bind:event="oninput"
                          placeholder="@L["SteerPlaceholder"]"
                          @onkeydown="OnSteerKeyDown"></textarea>
                <button @onclick="Steer" disabled="@string.IsNullOrWhiteSpace(_steerText)">@L["Send"]</button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string? RunId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private AgentRun? _run;
    private readonly List<StreamEvent> _events = new();
    private string _steerText = "";
    private IJSObjectReference? _sseModule;
    private string? _activeStreamId;
    private ElementReference _consoleRef;
    private bool _needsInitScroll;
    private bool _needsScroll;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_sseModule is null) return;
        if (_needsInitScroll)
        {
            _needsInitScroll = false;
            await _sseModule.InvokeVoidAsync("initAutoScroll", _consoleRef);
        }
        if (_needsScroll)
        {
            _needsScroll = false;
            await _sseModule.InvokeVoidAsync("scrollIfNeeded");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (RunId == _activeStreamId) return;
        await StopStream();
        _events.Clear();
        _run = RunId is null ? null : RunsState.Get(RunId);
        if (_run is null) return;

        _events.AddRange(_run.SnapshotBuffer());
        _run.OnEvent += HandleEvent;

        _sseModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/agent-sse.js");
        _activeStreamId = RunId;
        _needsInitScroll = true;
        StateHasChanged();
    }

    private void HandleEvent(StreamEvent ev)
    {
        _events.Add(ev);
        while (_events.Count > 500) _events.RemoveAt(0);
        _needsScroll = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task Close()
    {
        await StopStream();
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }

    private async Task StopStream()
    {
        if (_run is not null) _run.OnEvent -= HandleEvent;
        if (_sseModule is not null && _activeStreamId is not null)
            try { await _sseModule.InvokeVoidAsync("disposeAutoScroll"); } catch { }
        _activeStreamId = null;
    }

    private async Task OnSteerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Steer();
        }
    }

    private async Task Steer()
    {
        if (_run is null || string.IsNullOrWhiteSpace(_steerText)) return;
        var payload = new { text = _steerText };
        using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
        try
        {
            await http.PostAsJsonAsync($"/api/projects/{_run.ProjectSlug}/runs/{_run.RunId}/steer", payload);
            _events.Add(new StreamEvent(DateTime.UtcNow, "user", _steerText));
            _steerText = "";
        }
        catch { }
    }

    private async Task Stop()
    {
        if (_run is null) return;
        using var http = new HttpClient { BaseAddress = new Uri(Nav.BaseUri) };
        try { await http.PostAsync($"/api/projects/{_run.ProjectSlug}/runs/{_run.RunId}/stop", null); } catch { }
    }

    private static string GetMessageBody(string? text)
    {
        var (_, body) = ParseBracketTag(text);
        return body;
    }

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max] + "…";

    private static (string? Tag, string Body) ParseBracketTag(string? text)
    {
        if (string.IsNullOrEmpty(text)) return (null, "");
        if (!text.StartsWith('[')) return (null, text);
        var close = text.IndexOf(']');
        if (close < 1) return (null, text);
        var tag = text[1..close];
        var body = text[(close + 1)..].TrimStart();
        return (tag, body);
    }

    private static string GetResultPreview(string text)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(text);
            var root = doc.RootElement;
            if (root.TryGetProperty("result", out var r) && r.ValueKind == System.Text.Json.JsonValueKind.String)
                return Truncate(r.GetString() ?? "", 80);
            if (root.TryGetProperty("subtype", out var s))
                return s.GetString() ?? "result";
        }
        catch { }
        return Truncate(text, 80);
    }

    private static string GetRateLimitPreview(string text)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(text);
            var root = doc.RootElement;
            if (root.TryGetProperty("rate_limits", out var limits) && limits.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                var parts = limits.EnumerateArray()
                    .Select(l => l.TryGetProperty("name", out var n) && l.TryGetProperty("remaining", out var r)
                        ? $"{n.GetString()}={r}" : null)
                    .Where(s => s is not null);
                var preview = string.Join(", ", parts);
                return preview.Length > 0 ? preview : text;
            }
        }
        catch { }
        return Truncate(text, 80);
    }

    private static string GetToolPreview(string toolName, string? detail)
    {
        if (string.IsNullOrWhiteSpace(detail) || detail == "{}") return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(detail);
            var root = doc.RootElement;
            string? val = toolName switch
            {
                "Bash" => root.TryGetProperty("command", out var c) ? c.GetString() : null,
                "Read" => root.TryGetProperty("file_path", out var fp) ? fp.GetString() : null,
                "Write" => root.TryGetProperty("file_path", out var fp2) ? fp2.GetString() : null,
                "Edit" => root.TryGetProperty("file_path", out var fp3) ? fp3.GetString() : null,
                "Glob" => root.TryGetProperty("pattern", out var p) ? p.GetString() : null,
                "Grep" => root.TryGetProperty("pattern", out var gp) ? gp.GetString() : null,
                "WebFetch" or "WebSearch" => root.TryGetProperty("url", out var u) ? u.GetString()
                    : root.TryGetProperty("query", out var q) ? q.GetString() : null,
                _ => root.EnumerateObject().Select(x => x.Value.GetString()).FirstOrDefault()
            };
            return val is null ? "" : val.Length <= 80 ? val : val[..80] + "…";
        }
        catch { return ""; }
    }

    private static bool IsJson(string text)
    {
        var t = text.TrimStart();
        if (t.Length == 0) return false;
        if (t[0] != '{' && t[0] != '[') return false;
        try { System.Text.Json.JsonDocument.Parse(t); return true; } catch { return false; }
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch { return json; }
    }

    private static readonly System.Text.RegularExpressions.Regex _jsonTokenRe =
        new(@"(""(?:[^""\\]|\\.)*"")\s*(:)|""(?:[^""\\]|\\.)*""|(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)|true|false|null",
            System.Text.RegularExpressions.RegexOptions.Compiled);

    private static string HighlightJson(string? json)
    {
        var pretty = FormatJson(json);
        if (string.IsNullOrWhiteSpace(pretty)) return "";
        var sb = new System.Text.StringBuilder();
        var pos = 0;
        foreach (System.Text.RegularExpressions.Match m in _jsonTokenRe.Matches(pretty))
        {
            if (m.Index > pos)
                sb.Append(System.Net.WebUtility.HtmlEncode(pretty[pos..m.Index]));
            var encoded = System.Net.WebUtility.HtmlEncode(m.Value);
            if (m.Groups[2].Success)
            {
                var keyEncoded = System.Net.WebUtility.HtmlEncode(m.Groups[1].Value);
                sb.Append($"<span class=\"json-key\">{keyEncoded}</span>{m.Groups[2].Value}");
            }
            else if (m.Value.StartsWith('"'))
                sb.Append($"<span class=\"json-string\">{encoded}</span>");
            else if (m.Groups[3].Success)
                sb.Append($"<span class=\"json-number\">{encoded}</span>");
            else
                sb.Append(m.Value switch
                {
                    "true" or "false" => $"<span class=\"json-bool\">{encoded}</span>",
                    "null" => $"<span class=\"json-null\">{encoded}</span>",
                    _ => encoded
                });
            pos = m.Index + m.Length;
        }
        if (pos < pretty.Length)
            sb.Append(System.Net.WebUtility.HtmlEncode(pretty[pos..]));
        return sb.ToString();
    }

    private static readonly MarkdownPipeline _mdPipeline =
        new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private static string RenderMarkdown(string? text) =>
        string.IsNullOrEmpty(text) ? "" : Markdig.Markdown.ToHtml(text, _mdPipeline);

    private static string FormatElapsed(DateTime start)
    {
        var d = DateTime.UtcNow - start;
        return d.TotalHours >= 1 ? $"{(int)d.TotalHours}h{d.Minutes:D2}" : $"{d.Minutes:D2}:{d.Seconds:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        await StopStream();
        if (_sseModule is not null)
        {
            try { await _sseModule.DisposeAsync(); } catch { }
        }
    }
}
