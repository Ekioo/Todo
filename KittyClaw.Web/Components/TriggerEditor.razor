@using KittyClaw.Core.Automation
@inject LocalizationService L

<div class="node-editor">
    <label>@L["Type"]
        <select value="@CurrentType" @onchange="OnTypeChanged">
            <option value="interval">@L["TrigTypeInterval"]</option>
            <option value="ticketInColumn">@L["TrigTypeTicketInColumn"]</option>
            <option value="gitCommit">@L["TrigTypeGitCommit"]</option>
            <option value="statusChange">@L["TrigTypeStatusChange"]</option>
            <option value="subTicketStatus">@L["TrigTypeSubTickets"]</option>
            <option value="boardIdle">@L["TrigTypeBoardIdle"]</option>
            <option value="agentInactivity">@L["TrigTypeAgentInactivity"]</option>
            <option value="ticketCommentAdded">@L["TrigTypeCommentAdded"]</option>
        </select>
    </label>

    @switch (Automation.Trigger)
    {
        case IntervalTriggerSpec s:
            <label>@L["IntervalSeconds"]
                <input type="number" value="@(s.Seconds?.ToString() ?? "")"
                       @onchange="e => { s.Seconds = string.IsNullOrWhiteSpace((string?)e.Value) ? null : int.Parse((string)e.Value!); if (s.Seconds is not null) s.Cron = null; }" />
            </label>
            <label>@L["CronLabel"]
                <input placeholder="@L["CronPlaceholder"]" value="@(s.Cron ?? "")"
                       @onchange="e => { s.Cron = string.IsNullOrWhiteSpace((string?)e.Value) ? null : (string)e.Value!; if (s.Cron is not null) s.Seconds = null; }" />
            </label>
            break;

        case TicketInColumnTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.Seconds" />
            </label>
            <div class="column-picker">
                <div class="column-picker-label">@L["ColumnsOneOrMore"]</div>
                @foreach (var c in Columns)
                {
                    var col = c;
                    <label class="column-check"><input type="checkbox" checked="@s.Columns.Contains(col)"
                               @onchange="e => ToggleColumn(s.Columns, col, (bool)e.Value!)" /><span>@col</span></label>
                }
            </div>
            <label>@L["AssigneeMemberOptional"]
                <select value="@(s.AssigneeSlug ?? "")" @onchange="e => s.AssigneeSlug = string.IsNullOrEmpty((string?)e.Value) ? null : (string)e.Value!">
                    <option value="">@L["AnyMemberOption"]</option>
                    @foreach (var sk in Skills) { <option value="@sk">@sk</option> }
                </select>
            </label>
            <label>@L["DebounceSeconds"]
                <input type="number" @bind="s.DebounceSeconds" />
            </label>
            break;

        case GitCommitTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <label>@L["IgnoreAuthorsHint"]
                <input placeholder="noreply@anthropic.com, bot@example.com" value="@string.Join(", ", s.IgnoreAuthors)"
                       @onchange="e => ParseIgnoreAuthors(s, (string?)e.Value)" />
            </label>
            break;

        case StatusChangeTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <label>@L["FromOptional"]
                <select value="@(s.From ?? "")" @onchange="e => s.From = string.IsNullOrEmpty((string?)e.Value) ? null : (string)e.Value!">
                    <option value="">@L["AnyOption"]</option>
                    @foreach (var c in Columns) { <option value="@c">@c</option> }
                </select>
            </label>
            <label>@L["ToOptional"]
                <select value="@(s.To ?? "")" @onchange="e => s.To = string.IsNullOrEmpty((string?)e.Value) ? null : (string)e.Value!">
                    <option value="">@L["AnyOption"]</option>
                    @foreach (var c in Columns) { <option value="@c">@c</option> }
                </select>
            </label>
            <label>@L["DebounceSeconds"]
                <input type="number" value="@(s.DebounceSeconds?.ToString() ?? "")"
                       @onchange="e => s.DebounceSeconds = int.TryParse((string?)e.Value, out var v) ? v : null" />
            </label>
            break;

        case SubTicketStatusTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <label>@L["ParentColumnOptional"]
                <select value="@(s.ParentColumn ?? "")" @onchange="e => s.ParentColumn = string.IsNullOrEmpty((string?)e.Value) ? null : (string)e.Value!">
                    <option value="">@L["AllColumns"]</option>
                    @foreach (var c in Columns) { <option value="@c">@c</option> }
                </select>
            </label>
            <label>@L["DebounceSeconds"]
                <input type="number" value="@(s.DebounceSeconds?.ToString() ?? "")"
                       @onchange="e => s.DebounceSeconds = int.TryParse((string?)e.Value, out var v) ? v : null" />
            </label>
            break;

        case BoardIdleTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <div class="column-picker">
                <div class="column-picker-label">@L["IdleColumnsHint"]</div>
                @foreach (var c in Columns)
                {
                    var col = c;
                    <label class="column-check">
                        <input type="checkbox" checked="@s.IdleColumns.Contains(col)"
                               @onchange="e => ToggleColumn(s.IdleColumns, col, (bool)e.Value!)" />
                        <span>@col</span>
                    </label>
                }
            </div>
            break;

        case AgentInactivityTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <label>@L["InactivityMinutes"]
                <input type="number" @bind="s.MinutesIdle" />
            </label>
            break;

        case TicketCommentAddedTriggerSpec s:
            <label>@L["PollSeconds"]
                <input type="number" @bind="s.PollSeconds" />
            </label>
            <label>@L["AuthorsFilterHint"]
                <input placeholder="owner, programmer" value="@string.Join(", ", s.Authors)"
                       @onchange="e => ParseAuthors(s, (string?)e.Value)" />
            </label>
            break;
    }
</div>

@code {
    [Parameter] public Automation Automation { get; set; } = default!;
    [Parameter] public List<string> Skills { get; set; } = new();
    [Parameter] public List<string> Columns { get; set; } = new();
    [Parameter] public EventCallback<TriggerSpec> OnReplace { get; set; }

    private string CurrentType => Automation.Trigger switch
    {
        IntervalTriggerSpec => "interval",
        TicketInColumnTriggerSpec => "ticketInColumn",
        GitCommitTriggerSpec => "gitCommit",
        StatusChangeTriggerSpec => "statusChange",
        SubTicketStatusTriggerSpec => "subTicketStatus",
        BoardIdleTriggerSpec => "boardIdle",
        AgentInactivityTriggerSpec => "agentInactivity",
        TicketCommentAddedTriggerSpec => "ticketCommentAdded",
        _ => "interval",
    };

    private async Task OnTypeChanged(ChangeEventArgs e)
    {
        TriggerSpec spec = (string?)e.Value switch
        {
            "interval" => new IntervalTriggerSpec { Seconds = 60 },
            "ticketInColumn" => new TicketInColumnTriggerSpec {
                Columns = new List<string> { Columns.FirstOrDefault() ?? "Todo" },
                Seconds = 30
            },
            "gitCommit" => new GitCommitTriggerSpec { PollSeconds = 60 },
            "statusChange" => new StatusChangeTriggerSpec { PollSeconds = 30 },
            "subTicketStatus" => new SubTicketStatusTriggerSpec { PollSeconds = 30 },
            "boardIdle" => new BoardIdleTriggerSpec { PollSeconds = 60 },
            "agentInactivity" => new AgentInactivityTriggerSpec { PollSeconds = 60, MinutesIdle = 45 },
            "ticketCommentAdded" => new TicketCommentAddedTriggerSpec { PollSeconds = 30 },
            _ => new IntervalTriggerSpec { Seconds = 60 },
        };
        await OnReplace.InvokeAsync(spec);
    }

    private static void ParseIgnoreAuthors(GitCommitTriggerSpec spec, string? value)
    {
        spec.IgnoreAuthors = (value ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    private static void ParseAuthors(TicketCommentAddedTriggerSpec spec, string? value)
    {
        spec.Authors = (value ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    private void ToggleColumn(List<string> list, string col, bool on)
    {
        if (on) { if (!list.Contains(col)) list.Add(col); }
        else { list.Remove(col); }
    }
}
