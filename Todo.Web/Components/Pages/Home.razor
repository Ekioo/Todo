@page "/"
@using Todo.Core.Models
@using Todo.Core.Services
@inject ProjectService ProjectService
@inject LocalizationService L
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>@L["HomeTitle"]</PageTitle>

<div class="page-header">
    <h1>@L["Projects"]</h1>
</div>

<div class="project-list">
    @if (_projects is not null)
    {
        @foreach (var project in _projects)
        {
            <div class="project-card-wrap @(project.IsPaused ? "project-paused" : "")">
                <a class="project-card" href="/board/@project.Slug">
                    <h3>
                        @project.Name
                        @if (project.IsPaused)
                        {
                            <span class="project-paused-badge">⏸ @L["Paused"]</span>
                        }
                    </h3>
                    <small>@project.Slug</small>
                </a>
                <button class="project-pause-btn" title="@(project.IsPaused ? L["Resume"] : L["Pause"])"
                        @onclick="() => TogglePause(project)" @onclick:stopPropagation>
                    @(project.IsPaused ? "▶" : "⏸")
                </button>
                <button class="project-delete-btn" title="@L["Delete"]" @onclick="() => AskDelete(project)">&times;</button>
            </div>
        }
    }
</div>

<div class="create-project">
    <input @bind="_newProjectName" @bind:event="oninput" placeholder="@L["NewProjectPlaceholder"]"
           @onkeydown="HandleKeyDown" />
    <button @onclick="CreateProject" disabled="@string.IsNullOrWhiteSpace(_newProjectName)">@L["Create"]</button>
</div>

@if (_deleteTarget is not null)
{
    <div class="confirm-overlay" @onclick="CancelDelete">
        <div class="confirm-dialog" @onclick:stopPropagation>
            <p>@L["DeleteProjectConfirm"] <strong>@_deleteTarget.Name</strong>&#160;?</p>
            <p class="confirm-warning">@L["DeleteProjectWarning"]</p>
            <div class="confirm-actions">
                <button class="cancel-btn" @onclick="CancelDelete">@L["Cancel"]</button>
                <button class="delete-btn" @onclick="ConfirmDelete">@L["Delete"]</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Project>? _projects;
    private string _newProjectName = "";
    private Project? _deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += OnLangChanged;
        _projects = await ProjectService.ListProjectsAsync();
    }

    private async Task CreateProject()
    {
        if (string.IsNullOrWhiteSpace(_newProjectName)) return;
        await ProjectService.CreateProjectAsync(_newProjectName.Trim());
        _newProjectName = "";
        _projects = await ProjectService.ListProjectsAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await CreateProject();
    }

    private async Task TogglePause(Project project)
    {
        var updated = await ProjectService.TogglePauseAsync(project.Slug);
        if (updated is not null)
        {
            var idx = _projects!.IndexOf(project);
            if (idx >= 0) _projects[idx] = updated;
        }
    }

    private void AskDelete(Project project) => _deleteTarget = project;
    private void CancelDelete() => _deleteTarget = null;

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        await ProjectService.DeleteProjectAsync(_deleteTarget.Slug);
        _deleteTarget = null;
        _projects = await ProjectService.ListProjectsAsync();
    }

    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => L.OnLanguageChanged -= OnLangChanged;
}
