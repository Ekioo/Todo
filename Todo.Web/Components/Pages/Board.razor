    private void StartDeleteColumn(int columnId)
    {
        var col = _columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null) return;
        _trashConfirmColumn = col;
        var first = _columns.FirstOrDefault(c => c.Id != columnId);
        _deleteColumnMoveTo = first?.Name ?? "";
    }

    private async Task DeleteColumn(int columnId)
    {
        if (string.IsNullOrEmpty(_deleteColumnMoveTo)) return;
        await ColumnService.DeleteColumnAsync(Slug, columnId, _deleteColumnMoveTo);
        _trashConfirmColumn = null;
        _columns = await ColumnService.ListColumnsAsync(Slug);
        _tickets = await TicketService.ListTicketsAsync(Slug);
        RebuildPipeline();
    }

    // Trash zone handlers
    private void OnTrashDragOver()
    {
        _trashHover = true;
    }

    private void OnTrashDrop()
    {
        _trashHover = false;
        if (_draggedColumn is not null)
        {
            _trashConfirmColumn = _draggedColumn;
            var first = _columns.FirstOrDefault(c => c.Id != _draggedColumn.Id);
            _deleteColumnMoveTo = first?.Name ?? "";
            _draggedColumn = null;
            _colDropIndex = -1;
        }
        else if (_draggedTicket is not null)
        {
            _trashConfirmTicket = _draggedTicket;
            _draggedTicket = null;
            _dragOverStatus = null;
            _dragInsertIndex = -1;
        }
    }

    private void CancelTrash()
    {
        _trashConfirmColumn = null;
        _trashConfirmTicket = null;
    }

    private async Task ConfirmTrashColumn()
    {
        if (_trashConfirmColumn is null) return;
        await DeleteColumn(_trashConfirmColumn.Id);
    }

    private async Task ConfirmTrashTicket()
    {
        if (_trashConfirmTicket is null) return;
        await TicketService.DeleteTicketAsync(Slug, _trashConfirmTicket.Id);
        _trashConfirmTicket = null;
        _tickets = await TicketService.ListTicketsAsync(Slug);
        RebuildPipeline();
    }

    // ── Label autocomplete ──
    private List<Label> GetLabelSuggestions()
    {
        if (_selectedTicket is null) return [];
        var currentIds = _selectedTicket.Labels.Select(l => l.Id).ToHashSet();
        var query = _labelSearch?.Trim() ?? "";
        return _allLabels
            .Where(l => !currentIds.Contains(l.Id))
            .Where(l => string.IsNullOrEmpty(query) || l.Name.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task AddExistingLabel(Label label)
    {
        if (_selectedTicket is null) return;
        var ids = _selectedTicket.Labels.Select(l => l.Id).ToList();
        ids.Add(label.Id);
        await TicketService.SetTicketLabelsAsync(Slug, _selectedTicket.Id, ids);
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        _tickets = await TicketService.ListTicketsAsync(Slug);
        _labelSearch = "";
        _labelDropdownOpen = false;
    }

    private async Task RemoveLabel(int labelId)
    {
        if (_selectedTicket is null) return;
        var ids = _selectedTicket.Labels.Select(l => l.Id).Where(id => id != labelId).ToList();
        await TicketService.SetTicketLabelsAsync(Slug, _selectedTicket.Id, ids);
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        _tickets = await TicketService.ListTicketsAsync(Slug);
    }

    private async Task CreateAndAddLabel()
    {
        if (_selectedTicket is null || string.IsNullOrWhiteSpace(_labelSearch)) return;
        var label = await LabelService.CreateLabelAsync(Slug, _labelSearch.Trim(), "#6366f1");
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        var ids = _selectedTicket.Labels.Select(l => l.Id).ToList();
        ids.Add(label.Id);
        await TicketService.SetTicketLabelsAsync(Slug, _selectedTicket.Id, ids);
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        _tickets = await TicketService.ListTicketsAsync(Slug);
        _labelSearch = "";
        _labelDropdownOpen = false;
    }

    private async Task HandleLabelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_labelSearch))
        {
            var suggestions = GetLabelSuggestions();
            if (suggestions.Count > 0)
                await AddExistingLabel(suggestions[0]);
            else
                await CreateAndAddLabel();
        }
        else if (e.Key == "Escape")
        {
            _labelSearch = "";
            _labelDropdownOpen = false;
        }
    }

    private void OnLabelBlur()
    {
        // Small delay handled by @onmousedown on dropdown items
        _labelDropdownOpen = false;
    }

