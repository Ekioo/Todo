@page "/board/{Slug}"
@page "/board/{Slug}/ticket/{TicketId:int}"
@page "/board/{Slug}/sub/{ParentId:int}"
@page "/board/{Slug}/sub/{ParentId:int}/ticket/{TicketId:int}"
@using Markdig
@using Microsoft.AspNetCore.Components
@using Todo.Core.Models
@using Todo.Core.Services
@using Todo.Web.Extensions
@inject ProjectService ProjectService
@inject TicketService TicketService
@inject Todo.Web.Services.BoardFilterState FilterState
@inject Todo.Web.Services.BoardUpdateNotifier BoardUpdateNotifier
@inject Todo.Web.Services.AgentRunsState AgentRuns
@inject LabelService LabelService
@inject ColumnService ColumnService
@inject MemberService MemberService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject LocalizationService L
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>@(_project?.Name ?? "Board")</PageTitle>

@if (_project is null)
{
    <p>@L["ProjectNotFound"]</p>
}
else
{
    <div class="page-header">
        <a href="/" class="back-link">&larr; @L["BackToProjects"]</a>
        <h1>@_project.Name</h1>
        @if (_subKanbanParentId is not null && _subKanbanParent is not null)
        {
            <div class="sub-kanban-breadcrumb">
                <button class="breadcrumb-back" @onclick="ExitSubKanban">&larr; @L["MainBoard"]</button>
                <span class="breadcrumb-separator">/</span>
                <span class="breadcrumb-parent">#@_subKanbanParent.Id &mdash; @_subKanbanParent.Title</span>
            </div>
        }
        <div class="filter-bar">
            <div class="filter-input-wrapper">
                <span class="filter-icon">&#128269;</span>
                <input class="filter-input"
                       placeholder="@L["Filter"]"
                       @bind="_filterText"
                       @bind:event="oninput"
                       @onfocus="() => _filterHintVisible = true"
                       @onblur="OnFilterBlur" />
                @if (!string.IsNullOrEmpty(_filterText))
                {
                    <button class="filter-clear" @onclick="() => _filterText = string.Empty">&times;</button>
                }
                @if (_filterHintVisible)
                {
                    <div class="filter-hint-popup">
                        <div class="filter-hint-title">@L["FilterSyntax"]</div>
                        <div class="filter-hint-row"><code>#42</code> @L["FilterByNumber"]</div>
                        <div class="filter-hint-row"><code>@@owner</code> @L["FilterAssignedTo"]</div>
                        <div class="filter-hint-row"><code>&gt;2026-03-01</code> @L["FilterAfter"]</div>
                        <div class="filter-hint-row"><code>&lt;2026-03-28</code> @L["FilterBefore"]</div>
                        <div class="filter-hint-row"><code>priority:critical</code> @L["FilterByPriority"]</div>
                        <div class="filter-hint-row"><code>label:bug</code> @L["FilterByLabel"]</div>
                        <div class="filter-hint-row"><code>by:owner</code> @L["FilterCreatedBy"]</div>
                        <div class="filter-hint-row">@L["FilterFreeText"]</div>
                    </div>
                }
            </div>
        </div>
        <div class="header-right">
            <button class="header-action-btn pause-btn @(_project.IsPaused ? "pause-btn--paused" : "")"
                    title="@(_project.IsPaused ? L["Resume"] : L["Pause"])"
                    @onclick="ToggleProjectPause">
                @(_project.IsPaused ? "▶ " + L["Resume"] : "⏸ " + L["Pause"])
            </button>
            <button class="header-action-btn undo-btn"
                    @onclick="PerformUndo"
                    disabled="@(!_undoStack.Any())"
                    title="@(_undoStack.Any() ? $"{L["UndoPrefix"]} : {_undoStack.Peek().Label}" : L["UndoNothing"])">
                &#8630;
            </button>
            <a class="header-action-btn" href="/board/@Slug/automations" title="@L["Automations"]">&#9881; @L["Automations"]</a>
            <a class="header-action-btn" href="/board/@Slug/settings" title="@L["ProjectSettingsTooltip"]">&#9881;&#65039; @L["ProjectSettings"]</a>
        </div>
    </div>

    <div class="board">
        @foreach (var col in _columns)
        {
            var colIndex = _columns.IndexOf(col);
            <div class="column @(_draggedColumn?.Id == col.Id ? "column-dragging" : "")"
                 style="--col-color: @col.Color"
                 @ondragover="(e) => OnDragOverColumn(col.Name, e)"
                 @ondragover:preventDefault
                 @ondrop="() => OnDrop(col.Name)"
                 @ondrop:preventDefault>
                @if (_draggedColumn is not null && _draggedTicket is null && _colDropIndex == colIndex && _draggedColumn.Id != col.Id)
                {
                    <div class="column-drop-indicator"></div>
                }
                <div class="column-header"
                     draggable="true"
                     @ondragstart="() => OnColumnDragStart(col)"
                     @ondragend="OnColumnDragEnd"
                     @ondragover="(e) => OnColumnDragOver(colIndex, e)"
                     @ondragover:preventDefault
                     @ondrop="OnColumnDrop"
                     @ondrop:preventDefault>
                    <span class="status-pill" style="color: @col.Color; background: color-mix(in srgb, @col.Color 12%, transparent)">@col.Name</span>
                    <span class="count">@GetTickets(col.Name).Count</span>
                </div>
                <div class="column-body">
                    @{ var columnTickets = GetTickets(col.Name); }
                    @for (int i = 0; i <= columnTickets.Count; i++)
                    {
                        var slotIndex = i;
                        @if (_draggedTicket is not null)
                        {
                            var isActiveSlot = _dragOverStatus == col.Name && _dragActiveSlot == slotIndex && !IsNoOpReorder(col.Name, slotIndex);
                            <div class="drop-slot @(isActiveSlot ? "active" : "")"
                                 @ondragover="() => OnDragOverSlot(col.Name, slotIndex)"
                                 @ondragover:preventDefault
                                 @ondragover:stopPropagation
                                 @ondrop="() => OnDropReorder(col.Name, slotIndex)"
                                 @ondrop:preventDefault
                                 @ondrop:stopPropagation>
                                @if (isActiveSlot) { <span>@L["PlaceHere"]</span> }
                            </div>
                        }
                        @if (i < columnTickets.Count)
                        {
                            var ticket = columnTickets[i];
                            var index = i;
                            var isCardTarget = _draggedTicket is not null && _dragActiveSlot < 0 && _dragOverStatus == col.Name && _dragHoverIndex == index && _dropTargetTicketId == ticket.Id;
                            <div class="ticket-card @(_selectedTicket?.Id == ticket.Id ? "selected" : "") @(_draggedTicket?.Id == ticket.Id ? "dragging" : "") @(isCardTarget ? "drop-target" : "") @(IsTicketUpdated(ticket) ? "ticket-updated" : "")"
                                 draggable="true"
                                 @ondragstart="() => OnDragStart(ticket)"
                                 @ondragend="OnDragEnd"
                                 @ondragover="() => OnDragOverCard(col.Name, index, ticket)"
                                 @ondragover:preventDefault
                                 @ondragover:stopPropagation
                                 @ondrop="() => OnDropAsChild(ticket, col.Name)"
                                 @ondrop:preventDefault
                                 @ondrop:stopPropagation
                                 @onclick="() => SelectTicket(ticket)">
                                <div class="ticket-card-top">
                                    <span class="priority-dot priority-@GetPriorityClass(ticket.Priority)" title="@GetPriorityLabel(ticket.Priority)"></span>
                                    @{
                                        var activeRun = AgentRuns.ActiveForTicket(Slug, ticket.Id);
                                        var lastRun = activeRun is null ? AgentRuns.LastForTicket(Slug, ticket.Id) : null;
                                    }
                                    @if (activeRun is not null)
                                    {
                                        <span class="agent-spinner"
                                              title="@activeRun.AgentName en cours"
                                              @onclick="() => OpenRunDrawer(activeRun.RunId)"
                                              @onclick:stopPropagation></span>
                                    }
                                    else if (lastRun is not null)
                                    {
                                        <button class="agent-log-btn agent-log-@lastRun.Status.ToString().ToLowerInvariant()"
                                                title="Voir le dernier run (@lastRun.AgentName · @lastRun.Status)"
                                                @onclick="() => OpenRunDrawer(lastRun.RunId)"
                                                @onclick:stopPropagation>log</button>
                                    }
                                    <span class="ticket-id">#@ticket.Id</span>
                                </div>
                                <span class="ticket-title">@ticket.Title</span>
                                @if (ticket.Labels.Count > 0)
                                {
                                    <div class="label-list">
                                        @foreach (var label in ticket.Labels)
                                        {
                                            <span class="label-pill" style="--lc: @label.Color">@label.Name</span>
                                        }
                                    </div>
                                }
                                @if (ticket.SubTickets.Count > 0)
                                {
                                    <div class="sub-ticket-indicator" @onclick="() => EnterSubKanban(ticket)" @onclick:stopPropagation title="@L["ViewSubTickets"]">
                                        <span class="sub-ticket-icon">&#128194;</span>
                                        <span>@ticket.SubTickets.Count(s => s.Status == _columns.LastOrDefault()?.Name)/@ticket.SubTickets.Count</span>
                                    </div>
                                }
                                <div class="ticket-card-bottom">
                                    @if (!string.IsNullOrEmpty(ticket.AssignedTo))
                                    {
                                        <span class="assignee-badge" title="@ticket.AssignedTo">@MemberDisplayName(ticket.AssignedTo)</span>
                                    }
                                    <small class="ticket-author">@ticket.CreatedBy</small>
                                </div>
                            </div>
                        }
                    }
                </div>
                @if (col == _columns[0])
                {
                    <div class="add-ticket">
                        <button class="add-ticket-btn" @onclick="OpenCreatePopup">+ @L["NewTicket"]</button>
                    </div>
                }
            </div>
        }

    </div>

    @* ── Trash drop zone (visible during drag) ── *@
    @if (_draggedTicket is not null || _draggedColumn is not null)
    {
        <div class="bottom-drop-zones">
            @if (_draggedTicket is not null && _subKanbanParentId is not null)
            {
                <div class="unparent-zone @(_unparentHover ? "unparent-zone-hover" : "")"
                     @ondragover="OnUnparentDragOver"
                     @ondragover:preventDefault
                     @ondragleave="() => _unparentHover = false"
                     @ondrop="OnUnparentDrop"
                     @ondrop:preventDefault>
                    <span class="unparent-icon">&#128279;</span>
                    <span>@L["Unparent"]</span>
                </div>
            }
            <div class="trash-zone @(_trashHover ? "trash-zone-hover" : "")"
                 @ondragover="OnTrashDragOver"
                 @ondragover:preventDefault
                 @ondragleave="() => _trashHover = false"
                 @ondrop="OnTrashDrop"
                 @ondrop:preventDefault>
                <span class="trash-icon">&#128465;</span>
                <span>@L["Delete"]</span>
            </div>
        </div>
    }

    @* ── Trash confirmation dialog ── *@
    @if (_trashConfirmColumn is not null)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>@L["DeleteColumnConfirm"] «&#160;@_trashConfirmColumn.Name&#160;»&#160;?</p>
                @if (_columns.Count > 1)
                {
                    <p class="confirm-warning">@L["MoveTicketsTo"]</p>
                    <select @bind="_deleteColumnMoveTo" style="margin-bottom:0.5rem;width:100%">
                        @foreach (var other in _columns.Where(c => c.Id != _trashConfirmColumn.Id))
                        {
                            <option value="@other.Name">@other.Name</option>
                        }
                    </select>
                }
                <div class="confirm-actions">
                    <button class="cancel-btn" @onclick="CancelTrash">@L["Cancel"]</button>
                    <button class="delete-btn" @onclick="ConfirmTrashColumn">@L["Delete"]</button>
                </div>
            </div>
        </div>
    }
    @if (_trashConfirmTicket is not null)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>@L["DeleteTicketConfirm"] #@_trashConfirmTicket.Id «&#160;@_trashConfirmTicket.Title&#160;»&#160;?</p>
                <div class="confirm-actions">
                    <button class="cancel-btn" @onclick="CancelTrash">@L["Cancel"]</button>
                    <button class="delete-btn" @onclick="ConfirmTrashTicket">@L["Delete"]</button>
                </div>
            </div>
        </div>
    }

    @* ── Create ticket popup ── *@
    @if (_showCreatePopup)
    {
        <div class="ticket-modal-overlay" @onmousedown="CloseCreatePopup">
            <div class="create-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>@L["NewTicket"]</h2>
                    <button class="close-btn" @onclick="CloseCreatePopup">&times;</button>
                </div>
                <div class="create-popup-body">
                    <label class="field-label">@L["Title"]</label>
                    <input class="create-input" @bind="_newTicketTitle" @bind:event="oninput" placeholder="@L["TicketTitlePlaceholder"]" />

                    <label class="field-label">@L["DescriptionMarkdown"]</label>
                    <textarea class="create-textarea" @bind="_newTicketDescription" placeholder="@L["DescriptionPlaceholder"]"></textarea>

                    <label class="field-label">@L["Priority"]</label>
                    <div class="priority-picker">
                        @foreach (var p in Enum.GetValues<TicketPriority>())
                        {
                            <button class="priority-option @(_newTicketPriority == p ? "active" : "")"
                                    @onclick="() => _newTicketPriority = p">
                                <span class="priority-dot priority-@GetPriorityClass(p)"></span>
                                @GetPriorityLabel(p)
                            </button>
                        }
                    </div>

                    <label class="field-label">@L["Labels"]</label>
                    <div class="label-picker">
                        @foreach (var label in _allLabels)
                        {
                            var selected = _newTicketLabelIds.Contains(label.Id);
                            <button class="label-toggle @(selected ? "active" : "")"
                                    style="--lc: @label.Color"
                                    @onclick="() => ToggleLabel(label.Id)">
                                @label.Name
                            </button>
                        }
                        @if (_showNewLabelForm)
                        {
                            <div class="new-label-form">
                                <input @bind="_newLabelName" placeholder="@L["LabelNamePlaceholder"]" />
                                <input type="color" @bind="_newLabelColor" />
                                <button class="save-btn icon-btn" @onclick="CreateLabel">&#10003;</button>
                                <button class="cancel-icon-btn icon-btn" @onclick="() => _showNewLabelForm = false">&#10005;</button>
                            </div>
                        }
                        else
                        {
                            <button class="label-add-btn" @onclick="() => _showNewLabelForm = true">+ Label</button>
                        }
                    </div>

                    <label class="field-label">@L["AssignTo"]</label>
                    <div class="assignee-picker-wrapper">
                        <select class="assignee-select" @bind="_newTicketAssignedTo">
                            <option value="">@L["Unassigned"]</option>
                            @foreach (var member in _allMembers)
                            {
                                <option value="@member.Slug">@member.Name (@member.Slug)</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="create-popup-footer">
                    <button class="cancel-btn" @onclick="CloseCreatePopup">@L["Cancel"]</button>
                    <button @onclick="CreateTicket" disabled="@string.IsNullOrWhiteSpace(_newTicketTitle)">@L["CreateTicket"]</button>
                </div>
            </div>
        </div>
    }

    @if (_selectedTicket is not null)
    {
        <div class="ticket-modal-overlay" @onmousedown="ClosePanel">
            <div class="ticket-panel" @onmousedown:stopPropagation>
            <div class="ticket-panel-header">
                <div class="editable-field">
                    <div class="priority-dot-btn" @onclick="() => _showPriorityPicker = !_showPriorityPicker" title="@L["ChangePriority"]">
                        <span class="priority-dot priority-@GetPriorityClass(_selectedTicket.Priority)"></span>
                    </div>
                    @if (_showPriorityPicker)
                    {
                        <div class="priority-dropdown">
                            @foreach (var p in Enum.GetValues<TicketPriority>())
                            {
                                <button class="priority-option @(_selectedTicket.Priority == p ? "active" : "")"
                                        @onclick="() => SetPriorityAndClose(p)">
                                    <span class="priority-dot priority-@GetPriorityClass(p)"></span>
                                    @GetPriorityLabel(p)
                                </button>
                            }
                        </div>
                    }
                    @if (_editingTitle)
                    {
                        <span class="ticket-id-prefix">#@_selectedTicket.Id &mdash;</span>
                        <input class="edit-title-input" @bind="_editTitle" @onkeydown="HandleTitleKeyDown" />
                        <button class="icon-btn save-btn" title="@L["Save"]" @onclick="SaveTitle">&#10003;</button>
                        <button class="icon-btn cancel-icon-btn" title="@L["Cancel"]" @onclick="() => _editingTitle = false">&#10005;</button>
                    }
                    else
                    {
                        <h2>#@_selectedTicket.Id &mdash; @_selectedTicket.Title</h2>
                        <button class="icon-btn pencil-btn" title="@L["EditTitle"]" @onclick="StartEditTitle">&#9998;</button>
                    }
                </div>
                <div class="header-actions">
                    <button class="close-btn" @onclick="ClosePanel">&times;</button>
                </div>
            </div>

            @* ── Labels row ── *@
            <div class="ticket-labels-row">
                @foreach (var label in _selectedTicket.Labels)
                {
                    var lid = label.Id;
                    <span class="label-pill label-removable" style="--lc: @label.Color">
                        @label.Name
                        <button class="label-remove-btn" @onclick="() => RemoveLabel(lid)">&times;</button>
                    </span>
                }
                <div class="label-autocomplete">
                    <input class="label-autocomplete-input"
                           placeholder="+ Label..."
                           @bind="_labelSearch"
                           @bind:event="oninput"
                           @onfocus="() => _labelDropdownOpen = true"
                           @onblur="OnLabelBlur"
                           @onkeydown="HandleLabelKeyDown" />
                    @if (_labelDropdownOpen && GetLabelSuggestions().Any())
                    {
                        <div class="label-dropdown">
                            @foreach (var suggestion in GetLabelSuggestions())
                            {
                                <button class="label-dropdown-item" style="--lc: @suggestion.Color"
                                        @onmousedown="() => AddExistingLabel(suggestion)">
                                    <span class="label-pill" style="--lc: @suggestion.Color">@suggestion.Name</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            @* ── Assignee row ── *@
            <div class="ticket-assignee-row">
                <span class="section-label-sm">@L["AssignedToLabel"]</span>
                @if (!string.IsNullOrEmpty(_selectedTicket.AssignedTo))
                {
                    <span class="assignee-pill">
                        @MemberDisplayName(_selectedTicket.AssignedTo)
                        <button class="label-remove-btn" @onclick="RemoveAssignee">&times;</button>
                    </span>
                }
                <div class="label-autocomplete">
                    <input class="label-autocomplete-input"
                           placeholder="@(string.IsNullOrEmpty(_selectedTicket.AssignedTo) ? L["AssignPlaceholder"] : L["ChangePlaceholder"])"
                           @bind="_assigneeSearch"
                           @bind:event="oninput"
                           @onfocus="() => _assigneeDropdownOpen = true"
                           @onblur="OnAssigneeBlur"
                           @onkeydown="HandleAssigneeKeyDown" />
                    @if (_assigneeDropdownOpen && GetAssigneeSuggestions().Any())
                    {
                        <div class="label-dropdown">
                            @foreach (var member in GetAssigneeSuggestions())
                            {
                                <button class="label-dropdown-item" @onmousedown="() => SetAssignee(member.Slug)">
                                    <span class="assignee-pill">@member.Name</span>
                                    <span class="member-slug-hint">@member.Slug</span>
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="ticket-meta">
                    <span>@_selectedTicket.Status</span>
                    <span>@_selectedTicket.CreatedBy</span>
                    <span>@_selectedTicket.CreatedAt.ToString("d")</span>
                </div>
            </div>

            @* ── Sub-tickets section ── *@
            @{ var selectedSummary = _tickets.FirstOrDefault(t => t.Id == _selectedTicket.Id); }
            @if (selectedSummary?.SubTickets is { Count: > 0 })
            {
                <div class="sub-tickets-section">
                    <div class="section-header">
                        <span class="section-label">@L["SubTickets"] (@selectedSummary.SubTickets.Count)</span>
                        <button class="sub-kanban-btn" @onclick="() => EnterSubKanban(selectedSummary)">@L["ViewAll"] &#8594;</button>
                    </div>
                    <div class="sub-ticket-list">
                        @foreach (var sub in selectedSummary.SubTickets)
                        {
                            <div class="sub-ticket-row">
                                <span class="sub-ticket-status-dot" style="background: @GetColumnColor(sub.Status)"></span>
                                <span class="sub-ticket-id">#@sub.Id</span>
                                <span class="sub-ticket-title">@sub.Title</span>
                                <span class="sub-ticket-status">@sub.Status</span>
                            </div>
                        }
                    </div>
                </div>
            }
            @if (_selectedTicket.ParentId is not null)
            {
                var parentSummary = _tickets.FirstOrDefault(t => t.Id == _selectedTicket.ParentId);
                <div class="parent-ticket-section">
                    <span class="section-label-sm">@L["Parent"]</span>
                    <span class="parent-ticket-link">#@_selectedTicket.ParentId @(parentSummary?.Title ?? "")</span>
                </div>
            }

            @* ── Ticket body (thread layout) ── *@
                <div class="ticket-panel-thread">
                    <div class="section-header">
                        <span class="section-label">@L["Description"]</span>
                        <button class="icon-btn pencil-btn" title="@L["EditDescription"]" @onclick="StartEditDescription">&#9998;</button>
                    </div>
                    <div class="ticket-desc markdown">
                        @if (_selectedTicket.Description is { Length: > 0 })
                        {
                            @((MarkupString)Markdown.ToHtml(_selectedTicket.Description, _mdPipeline))
                        }
                        else
                        {
                            <p class="empty-hint">@L["NoDescription"]</p>
                        }
                    </div>

                    <div class="thread-section-divider">
                        <div class="activity-header">
                            <span class="section-label">@L["Activity"]</span>
                            <button class="add-comment-btn-sm" @onclick="StartNewComment">@L["AddComment"]</button>
                        </div>
                        @foreach (var item in GetTimeline())
                        {
                            @if (item.IsComment)
                            {
                                <div class="timeline-comment">
                                    <div class="timeline-comment-header">
                                        <strong>@item.Author</strong>
                                        <small>@item.At.ToString("g")</small>
                                        @if (_editingCommentId != item.Id)
                                        {
                                            <button class="icon-btn pencil-btn" title="Modifier" @onclick="() => StartEditComment(item.Id!.Value, item.Text)">&#9998;</button>
                                        }
                                    </div>
                                    <div class="markdown">@((MarkupString)Markdown.ToHtml(item.Text, _mdPipeline))</div>
                                </div>
                            }
                            else
                            {
                                <div class="timeline-event">
                                    <span class="event-dot"></span>
                                    <div class="event-content">
                                        <span class="event-author">@item.Author</span>
                                        <span class="event-text">@item.Text</span>
                                        <small>@item.At.ToString("g")</small>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="panel-footer-actions">
                        @if (_confirmDelete)
                        {
                            <span class="confirm-delete-label">@L["DeleteThisTicketConfirm"]</span>
                            <button class="delete-btn" @onclick="DeleteSelectedTicket">@L["Confirm"]</button>
                            <button class="cancel-btn" @onclick="() => _confirmDelete = false">@L["Cancel"]</button>
                        }
                        else
                        {
                            <button class="delete-btn" @onclick="() => _confirmDelete = true">@L["DeleteThisTicket"]</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Label management popup ── *@
    @if (_showLabelManager)
    {
        <div class="ticket-modal-overlay" @onmousedown="() => _showLabelManager = false">
            <div class="label-manager-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>@L["LabelManagement"]</h2>
                    <button class="close-btn" @onclick="() => _showLabelManager = false">&times;</button>
                </div>
                <div class="label-manager-body">
                    @foreach (var label in _allLabels)
                    {
                        var lid = label.Id;
                        <div class="label-manager-row">
                            @if (_editingLabelId == lid)
                            {
                                <input class="label-manager-name" @bind="_editLabelName" placeholder="Nom..." />
                                <input type="color" class="label-manager-color" @bind="_editLabelColor" />
                                <button class="icon-btn save-btn" @onclick="() => SaveLabel(lid)">&#10003;</button>
                                <button class="icon-btn cancel-icon-btn" @onclick="() => _editingLabelId = null">&#10005;</button>
                            }
                            else
                            {
                                <span class="label-pill" style="--lc: @label.Color">@label.Name</span>
                                <button class="icon-btn pencil-btn" @onclick="() => StartEditLabel(label)">&#9998;</button>
                                <button class="icon-btn label-delete-icon" @onclick="() => DeleteManagedLabel(lid)">&times;</button>
                            }
                        </div>
                    }
                    <div class="label-manager-add">
                        <input @bind="_managerNewName" placeholder="@L["NewLabelPlaceholder"]" />
                        <input type="color" @bind="_managerNewColor" />
                        <button class="icon-btn save-btn" @onclick="CreateManagedLabel" disabled="@string.IsNullOrWhiteSpace(_managerNewName)">&#10003;</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Member management popup ── *@
    @if (_showMemberManager)
    {
        <div class="ticket-modal-overlay" @onmousedown="() => _showMemberManager = false">
            <div class="label-manager-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>@L["MemberManagement"]</h2>
                    <button class="close-btn" @onclick="() => _showMemberManager = false">&times;</button>
                </div>
                <div class="label-manager-body">
                    @foreach (var member in _allMembers)
                    {
                        var mid = member.Id;
                        <div class="label-manager-row">
                            @if (_editingMemberId == mid)
                            {
                                <input class="label-manager-name" @bind="_editMemberName" placeholder="Nom..." />
                                <button class="icon-btn save-btn" @onclick="() => SaveMember(mid)">&#10003;</button>
                                <button class="icon-btn cancel-icon-btn" @onclick="() => _editingMemberId = null">&#10005;</button>
                            }
                            else
                            {
                                <span class="assignee-pill">@member.Name</span>
                                <span class="member-slug-hint">@member.Slug</span>
                                <button class="icon-btn pencil-btn" @onclick="() => StartEditMember(member)">&#9998;</button>
                                <button class="icon-btn label-delete-icon" @onclick="() => DeleteManagedMember(mid)">&times;</button>
                            }
                        </div>
                    }
                    <div class="label-manager-add">
                        <input @bind="_managerNewMemberName" placeholder="@L["NewMemberPlaceholder"]" />
                        <button class="icon-btn save-btn" @onclick="CreateManagedMember" disabled="@string.IsNullOrWhiteSpace(_managerNewMemberName)">&#10003;</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(_fullscreenTarget))
{
