    protected override bool ShouldRender()
    {
        if (_suppressRender) { _suppressRender = false; return false; }
        return true;
    }

    // Last-visited tracking for "updated" badge
    private DateTime? _lastVisitedAt;

    private bool IsTicketUpdated(TicketSummary ticket)
    {
        if (_lastVisitedAt is null) return false;
        var activity = ticket.LastActivityAt ?? ticket.UpdatedAt;
        return activity > _lastVisitedAt.Value;
    }

    private async Task RefreshTicketsAndTouch()
    {
        _tickets = await TicketService.ListTicketsAsync(Slug);
        _lastVisitedAt = DateTime.UtcNow;
        await JS.InvokeVoidAsync("localStorage.setItem", $"board-last-visited-{Slug}", _lastVisitedAt.Value.ToString("O"));
    }

    // Undo
    private record UndoAction(string Label, Func<Task> Undo);
    private readonly Stack<UndoAction> _undoStack = new();
    private const int MaxUndoSize = 30;
    private IJSObjectReference? _undoHandler;
    private DotNetObjectReference<Board>? _dotNetRef;

    private void PushUndo(string label, Func<Task> undo)
    {
        if (_undoStack.Count >= MaxUndoSize)
        {
            var items = _undoStack.ToArray();
            _undoStack.Clear();
            for (int i = items.Length - 2; i >= 0; i--)
                _undoStack.Push(items[i]);
        }
        _undoStack.Push(new UndoAction(label, undo));
    }

    [JSInvokable]
    public async Task OnCtrlZ() => await PerformUndo();

    private async Task PerformUndo()
    {
        if (!_undoStack.Any()) return;
        var action = _undoStack.Pop();
        await action.Undo();
        await RefreshTicketsAndTouch();
        _columns = await ColumnService.ListColumnsAsync(Slug);
        if (_selectedTicket is not null)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        RebuildPipeline();
        StateHasChanged();
    }

    // Fullscreen editor
    private string _fullscreenTarget = ""; // "description", "newComment", "editComment"
    private string _fullscreenText = "";
    private ElementReference _editorTextarea;
    private bool _pasteListenerAttached = false;

    // Filter bar
    private string _filterText
    {
        get => FilterState.FilterText;
        set => FilterState.FilterText = value;
    }
    private bool _filterHintVisible = false;

    private void OnFilterBlur() => _filterHintVisible = false;

    private void OpenFullscreen(string target)
    {
        _fullscreenTarget = target;
        _fullscreenText = target switch
        {
            "description" => _selectedTicket?.Description ?? "",
            "newComment" => "",
            "editComment" => _editComment,
            _ => ""
        };
    }

    private void CancelFullscreen()
    {
        _fullscreenTarget = "";
        _fullscreenText = "";
        _pasteListenerAttached = false;
    }

    private async Task SaveFullscreen()
    {
        var target = _fullscreenTarget;
        var text = _fullscreenText;
        _fullscreenTarget = "";
        _fullscreenText = "";

        switch (target)
        {
            case "description":
                if (_selectedTicket is not null)
                {
                    var oldDesc = _selectedTicket.Description;
                    var descTicketId = _selectedTicket.Id;
                    await TicketService.UpdateTicketAsync(Slug, descTicketId, description: text);
                    PushUndo($"{L["UndoDescription"]} #{descTicketId}", async () =>
                        await TicketService.UpdateTicketAsync(Slug, descTicketId, description: oldDesc));
                    _selectedTicket = await TicketService.GetTicketAsync(Slug, descTicketId);
                }
                break;
            case "newComment":
                if (_selectedTicket is not null && !string.IsNullOrWhiteSpace(text))
                {
                    await TicketService.AddCommentAsync(Slug, _selectedTicket.Id, text.Trim());
                    _addingComment = false;
                    _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
                }
                break;
            case "editComment":
                if (_selectedTicket is not null && _editingCommentId is not null)
                {
                    var oldComment = _editComment;
                    var commentId = _editingCommentId.Value;
                    var editTicketId = _selectedTicket.Id;
                    await TicketService.UpdateCommentAsync(Slug, editTicketId, commentId, text.Trim());
                    PushUndo($"{L["UndoComment"]} #{editTicketId}", async () =>
                        await TicketService.UpdateCommentAsync(Slug, editTicketId, commentId, oldComment));
                    _editingCommentId = null;
                    _selectedTicket = await TicketService.GetTicketAsync(Slug, editTicketId);
                }
                break;
        }

        await RefreshTicketsAndTouch();
    }

    private MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private void RebuildPipeline()
    {
        var index = _tickets.ToDictionary(t => t.Id, t => t.Title);
        var memberHandles = new HashSet<string>(_allMembers.Select(m => m.Slug), StringComparer.OrdinalIgnoreCase);
        _mdPipeline = new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .Use(new TicketReferenceExtension(Slug, index))
            .Use(new MentionExtension(memberHandles))
            .Build();
    }

    private record TimelineItem(DateTime At, string Author, bool IsComment, string Text, int? Id);

    private IEnumerable<TimelineItem> GetTimeline()
    {
        if (_selectedTicket is null) return [];
        return _selectedTicket.Comments
            .Select(c => new TimelineItem(c.CreatedAt, c.Author, true, c.Content, c.Id))
            .Concat(_selectedTicket.Activities
                .Select(a => new TimelineItem(a.CreatedAt, a.Author, false, a.Text, null)))
            .OrderByDescending(x => x.At);
    }

    private string? _activeRunDrawerId;
    private async Task ToggleProjectPause()
    {
        var updated = await ProjectService.TogglePauseAsync(Slug);
        if (updated is not null) { _project = updated; StateHasChanged(); }
    }

    private void OpenRunDrawer(string runId) => _activeRunDrawerId = runId;
    private void CloseRunDrawer() => _activeRunDrawerId = null;
    private void OnAgentRunsChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        BoardUpdateNotifier.OnProjectUpdated += OnProjectUpdatedExternal;
        AgentRuns.OnChange += OnAgentRunsChanged;
        _project = await ProjectService.GetProjectAsync(Slug);
        if (_project is not null)
        {
            _columns = await ColumnService.ListColumnsAsync(Slug);
            _tickets = await TicketService.ListTicketsAsync(Slug);
            _allLabels = await LabelService.ListLabelsAsync(Slug);
            _allMembers = await MemberService.ListMembersAsync(Slug);
            RebuildPipeline();
        }
        if (ParentId.HasValue)
        {
            _subKanbanParentId = ParentId.Value;
            _subKanbanParent = _tickets.FirstOrDefault(t => t.Id == ParentId.Value);
        }
        if (TicketId.HasValue)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, TicketId.Value);
    }

    private void OnProjectUpdatedExternal(string slug)
    {
        if (slug != Slug) return;
        InvokeAsync(async () =>
        {
            _columns = await ColumnService.ListColumnsAsync(Slug);
            _tickets = await TicketService.ListTicketsAsync(Slug);
            _allLabels = await LabelService.ListLabelsAsync(Slug);
            _allMembers = await MemberService.ListMembersAsync(Slug);
            if (_selectedTicket is not null)
                _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
            RebuildPipeline();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        BoardUpdateNotifier.OnProjectUpdated -= OnProjectUpdatedExternal;
        AgentRuns.OnChange -= OnAgentRunsChanged;
        if (_undoHandler is not null)
            _ = JS.InvokeVoidAsync("unregisterUndoShortcut", _undoHandler);
        _dotNetRef?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_project is null) return; // handled by OnInitializedAsync

        // Sync sub-kanban state with URL
        if (ParentId.HasValue && _subKanbanParentId != ParentId.Value)
        {
            _subKanbanParentId = ParentId.Value;
            _subKanbanParent = _tickets.FirstOrDefault(t => t.Id == ParentId.Value);
        }
        else if (!ParentId.HasValue && _subKanbanParentId is not null)
        {
            _subKanbanParentId = null;
            _subKanbanParent = null;
        }

        if (TicketId.HasValue && _selectedTicket?.Id != TicketId)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, TicketId.Value);
        else if (!TicketId.HasValue && _selectedTicket is not null)
            _selectedTicket = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _undoHandler = await JS.InvokeAsync<IJSObjectReference>("registerUndoShortcut", _dotNetRef);

            // Load last-visited timestamp, then save current time
            var key = $"board-last-visited-{Slug}";
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", key);
            if (stored is not null && DateTime.TryParse(stored, null, System.Globalization.DateTimeStyles.RoundtripKind, out var parsed))
                _lastVisitedAt = parsed;
            await JS.InvokeVoidAsync("localStorage.setItem", key, DateTime.UtcNow.ToString("O"));
            StateHasChanged();
        }
        if (!string.IsNullOrEmpty(_fullscreenTarget) && !_pasteListenerAttached)
        {
            _pasteListenerAttached = true;
            await JS.InvokeVoidAsync("attachImagePaste", _editorTextarea, "/api/images");
        }
    }


    private List<TicketSummary> GetTickets(string status)
    {
        IEnumerable<TicketSummary> tickets;
        if (_subKanbanParentId is not null)
        {
            // Sub-kanban: only children of the parent ticket
            tickets = _tickets.Where(t => t.ParentId == _subKanbanParentId && t.Status == status);
        }
        else
        {
            // Main board: only top-level tickets (no parent)
            tickets = _tickets.Where(t => t.ParentId is null && t.Status == status);
        }

        if (!string.IsNullOrWhiteSpace(_filterText))
            tickets = ApplyFilter(tickets);

        return tickets.ToList();
    }

    private IEnumerable<TicketSummary> ApplyFilter(IEnumerable<TicketSummary> tickets)
    {
        var tokens = _filterText.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        foreach (var token in tokens)
        {
            // #N — ticket by number
            if (token.StartsWith('#') && int.TryParse(token[1..], out var id))
            {
                tickets = tickets.Where(t => t.Id == id);
                continue;
            }
            // @slug — assigned to
            if (token.StartsWith('@'))
            {
                var slug = token[1..];
                tickets = tickets.Where(t => t.AssignedTo != null && t.AssignedTo.Contains(slug, StringComparison.OrdinalIgnoreCase));
                continue;
            }
            // >date — updated after
            if (token.StartsWith('>') && DateTime.TryParse(token[1..], out var after))
            {
                tickets = tickets.Where(t => t.UpdatedAt >= after);
                continue;
            }
            // <date — updated before
            if (token.StartsWith('<') && DateTime.TryParse(token[1..], out var before))
            {
                tickets = tickets.Where(t => t.UpdatedAt <= before);
                continue;
            }
            // priority:xxx
            if (token.StartsWith("priority:", StringComparison.OrdinalIgnoreCase))
            {
                var pVal = token[9..];
                tickets = tickets.Where(t => GetPriorityLabel(t.Priority).Contains(pVal, StringComparison.OrdinalIgnoreCase)
                    || GetPriorityClass(t.Priority).Contains(pVal, StringComparison.OrdinalIgnoreCase));
                continue;
            }
            // label:xxx
            if (token.StartsWith("label:", StringComparison.OrdinalIgnoreCase))
            {
                var lVal = token[6..];
                tickets = tickets.Where(t => t.Labels.Any(l => l.Name.Contains(lVal, StringComparison.OrdinalIgnoreCase)));
                continue;
            }
            // by:xxx — created by
            if (token.StartsWith("by:", StringComparison.OrdinalIgnoreCase))
            {
                var byVal = token[3..];
                tickets = tickets.Where(t => t.CreatedBy.Contains(byVal, StringComparison.OrdinalIgnoreCase));
                continue;
            }
            // Free text — search in title, description & comments
            tickets = tickets.Where(t => t.Title.Contains(token, StringComparison.OrdinalIgnoreCase)
                || t.Description.Contains(token, StringComparison.OrdinalIgnoreCase));
        }
        return tickets;
    }

    private string GetPriorityLabel(TicketPriority p) => p switch
    {
        TicketPriority.Idea => L["PriorityIdea"],
        TicketPriority.NiceToHave => L["PriorityNiceToHave"],
        TicketPriority.Required => L["PriorityRequired"],
        TicketPriority.Critical => L["PriorityCritical"],
        _ => p.ToString()
    };

    private static string GetPriorityClass(TicketPriority p) => p switch
    {
        TicketPriority.Idea => "idea",
        TicketPriority.NiceToHave => "nice",
        TicketPriority.Required => "required",
        TicketPriority.Critical => "critical",
        _ => "nice"
    };

    private async Task SetPriority(TicketPriority p)
    {
        if (_selectedTicket is null || _selectedTicket.Priority == p) return;
        var oldPriority = _selectedTicket.Priority;
        var ticketId = _selectedTicket.Id;
        await TicketService.UpdateTicketAsync(Slug, ticketId, priority: p);
        PushUndo($"{L["UndoPriority"]} #{ticketId}", async () =>
            await TicketService.UpdateTicketAsync(Slug, ticketId, priority: oldPriority));
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
    }

    private async Task SetPriorityAndClose(TicketPriority p)
    {
        _showPriorityPicker = false;
        await SetPriority(p);
    }

    private void OnDragStart(TicketSummary ticket) => _draggedTicket = ticket;

    private void OnDragEnd()
    {
        _draggedTicket = null;
        _dragOverStatus = null;
        _dragHoverIndex = -1;
        _dragActiveSlot = -1;
        _trashHover = false;
        _unparentHover = false;
        _dropTargetTicketId = null;
    }

    // Column drag handlers
    private void OnColumnDragStart(BoardColumn col) => _draggedColumn = col;

    private void OnColumnDragEnd()
    {
        _draggedColumn = null;
        _colDropIndex = -1;
        _trashHover = false;
    }

    private void OnColumnDragOver(int colIndex, DragEventArgs e)
    {
        if (_draggedColumn is null) return;
        var newIdx = e.OffsetX < 115 ? colIndex : colIndex + 1;
        if (_colDropIndex == newIdx) { _suppressRender = true; return; }
        _colDropIndex = newIdx;
    }

    private async Task OnColumnDrop()
    {
        if (_draggedColumn is null) return;

        var targetIndex = _colDropIndex >= 0 ? _colDropIndex : _columns.Count;
        var currentIndex = _columns.FindIndex(c => c.Id == _draggedColumn.Id);
        if (currentIndex >= 0 && currentIndex < targetIndex)
            targetIndex--;

        await ColumnService.ReorderColumnAsync(Slug, _draggedColumn.Id, targetIndex);
        _columns = await ColumnService.ListColumnsAsync(Slug);
        _draggedColumn = null;
        _colDropIndex = -1;
    }

    private void OnDragOverCard(string status, int cardIndex, TicketSummary ticket)
    {
        if (_draggedTicket is null || _draggedTicket.Id == ticket.Id) return;
        var newDropTarget = (_subKanbanParentId is null) ? ticket.Id : (int?)null;
        if (_dragOverStatus == status && _dragHoverIndex == cardIndex && _dragActiveSlot == -1 && _dropTargetTicketId == newDropTarget)
        {
            _suppressRender = true;
            return;
        }
        _dragOverStatus = status;
        _dragHoverIndex = cardIndex;
        _dragActiveSlot = -1;
        _dropTargetTicketId = newDropTarget;
    }

    private void OnDragOverSlot(string status, int slotIndex)
    {
        if (_draggedTicket is null) return;
        if (_dragOverStatus == status && _dragActiveSlot == slotIndex && _dragHoverIndex == -1 && _dropTargetTicketId == null)
        {
            _suppressRender = true;
            return;
        }
        _dragOverStatus = status;
        _dragActiveSlot = slotIndex;
        _dragHoverIndex = -1;
        _dropTargetTicketId = null;
    }

    private void OnDragOverColumn(string status, DragEventArgs e)
    {
        if (_draggedTicket is null) return;
        var slotCount = GetTickets(status).Count;
        if (_dragOverStatus == status && _dragHoverIndex == -1 && _dragActiveSlot == slotCount && _dropTargetTicketId == null)
        {
            _suppressRender = true;
            return;
        }
        _dragOverStatus = status;
        _dragHoverIndex = -1;
        _dragActiveSlot = slotCount;
        _dropTargetTicketId = null;
    }

    private bool IsNoOpReorder(string colName, int slotIndex)
    {
        if (_draggedTicket is null || _draggedTicket.Status != colName) return false;
        var currentIndex = GetTickets(colName).FindIndex(t => t.Id == _draggedTicket.Id);
        if (currentIndex < 0) return false;
        return slotIndex == currentIndex || slotIndex == currentIndex + 1;
    }

    private async Task OnDrop(string newStatus)
    {
        if (_draggedTicket is null) return;
        await OnDropReorder(newStatus, GetTickets(newStatus).Count);
    }

    private async Task OnDropReorder(string newStatus, int targetIndex)
    {
        if (_draggedTicket is null) return;

        var oldStatus = _draggedTicket.Status;
        var oldIndex = _draggedTicket.SortOrder;
        var ticketId = _draggedTicket.Id;

        // Adjust for dragged item's removal
        if (_draggedTicket.Status == newStatus)
        {
            var currentIndex = GetTickets(newStatus).IndexOf(_draggedTicket);
            if (currentIndex >= 0 && currentIndex < targetIndex)
                targetIndex--;
        }

        await TicketService.ReorderTicketAsync(Slug, ticketId, newStatus, targetIndex);
        PushUndo($"{L["UndoMove"]} #{ticketId}", async () =>
            await TicketService.ReorderTicketAsync(Slug, ticketId, oldStatus, oldIndex));
        await RefreshTicketsAndTouch();
        _draggedTicket = null;
        _dragOverStatus = null;
        _dragHoverIndex = -1;
        _dragActiveSlot = -1;
        _dropTargetTicketId = null;
        RebuildPipeline();
    }

    private async Task OnDropAsChild(TicketSummary target, string colName)
    {
        if (_draggedTicket is null || _draggedTicket.Id == target.Id) return;

        // In main board: make child
        if (_dropTargetTicketId == target.Id && _subKanbanParentId is null)
        {
            var childId = _draggedTicket.Id;
            await TicketService.SetParentAsync(Slug, childId, target.Id);
            PushUndo($"{L["UndoAssociate"]} #{childId} → #{target.Id}", async () =>
                await TicketService.UnparentAsync(Slug, childId));
            _tickets = await TicketService.ListTicketsAsync(Slug);
            _draggedTicket = null;
            _dragOverStatus = null;
            _dragHoverIndex = -1;
            _dragActiveSlot = -1;
            _dropTargetTicketId = null;
            RebuildPipeline();
            return;
        }

        // In sub-kanban: reorder at this position
        await OnDropReorder(colName, GetTickets(colName).IndexOf(target));
    }

    // Sub-kanban
    private void EnterSubKanban(TicketSummary parent)
    {
        _subKanbanParentId = parent.Id;
        _subKanbanParent = parent;
        _selectedTicket = null;
        Navigation.NavigateTo($"/board/{Slug}/sub/{parent.Id}", replace: true);
    }

    private void ExitSubKanban()
    {
        _subKanbanParentId = null;
        _subKanbanParent = null;
        Navigation.NavigateTo($"/board/{Slug}", replace: true);
    }

    private string GetColumnColor(string status) =>
        _columns.FirstOrDefault(c => c.Name == status)?.Color ?? "#5a6a80";

    // Unparent drop zone
    private void OnUnparentDragOver() => _unparentHover = true;

    private async Task OnUnparentDrop()
    {
        _unparentHover = false;
        if (_draggedTicket is null) return;
        var childId = _draggedTicket.Id;
        var oldParentId = _subKanbanParentId!.Value;
        await TicketService.UnparentAsync(Slug, childId);
        PushUndo($"{L["UndoUnparent"]} #{childId}", async () =>
            await TicketService.SetParentAsync(Slug, childId, oldParentId));
        await RefreshTicketsAndTouch();
        _draggedTicket = null;
        _dragOverStatus = null;
        _dragHoverIndex = -1;
        _dragActiveSlot = -1;
        RebuildPipeline();
    }

    // Create popup
    private void OpenCreatePopup()
    {
        _newTicketTitle = "";
        _newTicketDescription = "";
        _newTicketLabelIds = [];
        _newTicketPriority = TicketPriority.NiceToHave;
        _newTicketAssignedTo = "";
        _showNewLabelForm = false;
        _showCreatePopup = true;
    }

    private void CloseCreatePopup() => _showCreatePopup = false;

    private void ToggleLabel(int id)
    {
        if (_newTicketLabelIds.Contains(id)) _newTicketLabelIds.Remove(id);
        else _newTicketLabelIds.Add(id);
    }

    private async Task CreateLabel()
    {
        if (string.IsNullOrWhiteSpace(_newLabelName)) return;
        var label = await LabelService.CreateLabelAsync(Slug, _newLabelName.Trim(), _newLabelColor);
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        _newTicketLabelIds.Add(label.Id);
        _newLabelName = "";
        _newLabelColor = "#6366f1";
        _showNewLabelForm = false;
    }

    private async Task CreateTicket()
    {
        if (string.IsNullOrWhiteSpace(_newTicketTitle) || _columns.Count == 0) return;
        var status = _columns[0].Name;
        var ticket = await TicketService.CreateTicketAsync(Slug, _newTicketTitle.Trim(), _newTicketDescription.Trim(), status: status, labelIds: _newTicketLabelIds, priority: _newTicketPriority, assignedTo: string.IsNullOrEmpty(_newTicketAssignedTo) ? null : _newTicketAssignedTo, parentId: _subKanbanParentId);
        if (ticket is not null)
            PushUndo($"{L["UndoCreate"]} #{ticket.Id}", async () =>
                await TicketService.DeleteTicketAsync(Slug, ticket.Id));
        _showCreatePopup = false;
        await RefreshTicketsAndTouch();
        RebuildPipeline();
    }

    private async Task SelectTicket(TicketSummary ticket)
    {
        _confirmDelete = false;
        _editingTitle = false;
        _editingCommentId = null;
        _fullscreenTarget = "";
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticket.Id);
        if (_subKanbanParentId is not null)
            Navigation.NavigateTo($"/board/{Slug}/sub/{_subKanbanParentId}/ticket/{ticket.Id}", replace: true);
        else
            Navigation.NavigateTo($"/board/{Slug}/ticket/{ticket.Id}", replace: true);
    }

    private void ClosePanel()
    {
        _selectedTicket = null;
        _confirmDelete = false;
        _editingTitle = false;
        _editingCommentId = null;
        _fullscreenTarget = "";
        _showPriorityPicker = false;
        _labelSearch = "";
        _labelDropdownOpen = false;
        _addingComment = false;
        if (_subKanbanParentId is not null)
            Navigation.NavigateTo($"/board/{Slug}/sub/{_subKanbanParentId}", replace: true);
        else
            Navigation.NavigateTo($"/board/{Slug}", replace: true);
    }

    private async Task DeleteSelectedTicket()
    {
        if (_selectedTicket is null) return;
        var t = _selectedTicket;
        var labelIds = t.Labels.Select(l => l.Id).ToList();
        await TicketService.DeleteTicketAsync(Slug, t.Id);
        PushUndo($"{L["UndoDelete"]} #{t.Id}", async () =>
            await TicketService.CreateTicketAsync(Slug, t.Title, t.Description, t.CreatedBy, t.Status, labelIds, t.Priority, t.AssignedTo, t.ParentId));
        _selectedTicket = null;
        _confirmDelete = false;
        await RefreshTicketsAndTouch();
        RebuildPipeline();
        Navigation.NavigateTo($"/board/{Slug}", replace: true);
    }

    private async Task AddComment()
    {
        if (_selectedTicket is null || string.IsNullOrWhiteSpace(_newComment)) return;
        await TicketService.AddCommentAsync(Slug, _selectedTicket.Id, _newComment.Trim());
        _newComment = "";
        _addingComment = false;
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        await RefreshTicketsAndTouch();
    }

    private void CancelComment()
    {
        _newComment = "";
        _addingComment = false;
    }

    private void StartNewComment()
    {
        OpenFullscreen("newComment");
    }

    // Title editing
    private void StartEditTitle()
    {
        _editTitle = _selectedTicket!.Title;
        _editingTitle = true;
    }

    private async Task SaveTitle()
    {
        if (_selectedTicket is null || string.IsNullOrWhiteSpace(_editTitle)) return;
        var oldTitle = _selectedTicket.Title;
        var ticketId = _selectedTicket.Id;
        await TicketService.UpdateTicketAsync(Slug, ticketId, title: _editTitle.Trim());
        PushUndo($"{L["UndoRename"]} #{ticketId}", async () =>
            await TicketService.UpdateTicketAsync(Slug, ticketId, title: oldTitle));
        _editingTitle = false;
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
        RebuildPipeline();
    }

    private async Task HandleTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveTitle();
        else if (e.Key == "Escape") _editingTitle = false;
    }

    // Description editing
    private void StartEditDescription()
    {
        OpenFullscreen("description");
    }

    // Comment editing
    private void StartEditComment(int commentId, string currentContent)
    {
        _editComment = currentContent;
        _editingCommentId = commentId;
        OpenFullscreen("editComment");
    }

    private async Task SaveComment()
    {
        if (_selectedTicket is null || _editingCommentId is null) return;
        await TicketService.UpdateCommentAsync(Slug, _selectedTicket.Id, _editingCommentId.Value, _editComment.Trim());
        _editingCommentId = null;
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        await RefreshTicketsAndTouch();
    }

    // Column management
    private async Task AddColumn()
    {
        if (string.IsNullOrWhiteSpace(_newColumnName)) return;
        var col = await ColumnService.CreateColumnAsync(Slug, _newColumnName.Trim(), _newColumnColor);
        if (col is not null)
            PushUndo($"{L["UndoColumn"]} {col.Name}", async () =>
            {
                await ColumnService.DeleteColumnAsync(Slug, col.Id, _columns.FirstOrDefault(c => c.Id != col.Id)?.Name ?? "Backlog");
            });
        _columns = await ColumnService.ListColumnsAsync(Slug);
        _newColumnName = "";
        _newColumnColor = "#5a6a80";
        _showAddColumn = false;
    }

    private void StartDeleteColumn(int columnId)
    {
        var col = _columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null) return;
        _trashConfirmColumn = col;
        var first = _columns.FirstOrDefault(c => c.Id != columnId);
        _deleteColumnMoveTo = first?.Name ?? "";
    }

    private async Task DeleteColumn(int columnId)
    {
        if (string.IsNullOrEmpty(_deleteColumnMoveTo)) return;
        await ColumnService.DeleteColumnAsync(Slug, columnId, _deleteColumnMoveTo);
        _trashConfirmColumn = null;
        _columns = await ColumnService.ListColumnsAsync(Slug);
        await RefreshTicketsAndTouch();
        RebuildPipeline();
    }

    // Trash zone handlers
    private void OnTrashDragOver()
    {
        _trashHover = true;
    }

    private void OnTrashDrop()
    {
        _trashHover = false;
        if (_draggedColumn is not null)
        {
            _trashConfirmColumn = _draggedColumn;
            var first = _columns.FirstOrDefault(c => c.Id != _draggedColumn.Id);
            _deleteColumnMoveTo = first?.Name ?? "";
            _draggedColumn = null;
            _colDropIndex = -1;
        }
        else if (_draggedTicket is not null)
        {
            _trashConfirmTicket = _draggedTicket;
            _draggedTicket = null;
            _dragOverStatus = null;
            _dragHoverIndex = -1;
            _dragActiveSlot = -1;
        }
    }

    private void CancelTrash()
    {
        _trashConfirmColumn = null;
        _trashConfirmTicket = null;
    }

    private async Task ConfirmTrashColumn()
    {
        if (_trashConfirmColumn is null) return;
        await DeleteColumn(_trashConfirmColumn.Id);
    }

    private async Task ConfirmTrashTicket()
    {
        if (_trashConfirmTicket is null) return;
        var t = _trashConfirmTicket;
        var full = await TicketService.GetTicketAsync(Slug, t.Id);
        var labelIds = full?.Labels.Select(l => l.Id).ToList() ?? [];
        await TicketService.DeleteTicketAsync(Slug, t.Id);
        PushUndo($"{L["UndoDelete"]} #{t.Id}", async () =>
            await TicketService.CreateTicketAsync(Slug, t.Title, t.Description, t.CreatedBy, t.Status, labelIds, t.Priority, t.AssignedTo, t.ParentId));
        _trashConfirmTicket = null;
        await RefreshTicketsAndTouch();
        RebuildPipeline();
    }

    // ── Label autocomplete ──
    private List<Label> GetLabelSuggestions()
    {
        if (_selectedTicket is null) return [];
        var currentIds = _selectedTicket.Labels.Select(l => l.Id).ToHashSet();
        var query = _labelSearch?.Trim() ?? "";
        return _allLabels
            .Where(l => !currentIds.Contains(l.Id))
            .Where(l => string.IsNullOrEmpty(query) || l.Name.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task AddExistingLabel(Label label)
    {
        if (_selectedTicket is null) return;
        var oldIds = _selectedTicket.Labels.Select(l => l.Id).ToList();
        var ticketId = _selectedTicket.Id;
        var ids = oldIds.ToList();
        ids.Add(label.Id);
        await TicketService.SetTicketLabelsAsync(Slug, ticketId, ids);
        PushUndo($"{L["UndoLabel"]} +{label.Name} #{ticketId}", async () =>
            await TicketService.SetTicketLabelsAsync(Slug, ticketId, oldIds));
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
        _labelSearch = "";
        _labelDropdownOpen = false;
    }

    private async Task RemoveLabel(int labelId)
    {
        if (_selectedTicket is null) return;
        var oldIds = _selectedTicket.Labels.Select(l => l.Id).ToList();
        var ticketId = _selectedTicket.Id;
        var ids = oldIds.Where(id => id != labelId).ToList();
        await TicketService.SetTicketLabelsAsync(Slug, ticketId, ids);
        PushUndo($"{L["UndoLabel"]} #{ticketId}", async () =>
            await TicketService.SetTicketLabelsAsync(Slug, ticketId, oldIds));
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
    }

    private async Task CreateAndAddLabel()
    {
        if (_selectedTicket is null || string.IsNullOrWhiteSpace(_labelSearch)) return;
        var label = await LabelService.CreateLabelAsync(Slug, _labelSearch.Trim(), "#6366f1");
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        var ids = _selectedTicket.Labels.Select(l => l.Id).ToList();
        ids.Add(label.Id);
        await TicketService.SetTicketLabelsAsync(Slug, _selectedTicket.Id, ids);
        _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        await RefreshTicketsAndTouch();
        _labelSearch = "";
        _labelDropdownOpen = false;
    }

    private async Task HandleLabelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_labelSearch))
        {
            var suggestions = GetLabelSuggestions();
            if (suggestions.Count > 0)
                await AddExistingLabel(suggestions[0]);
            else
                await CreateAndAddLabel();
        }
        else if (e.Key == "Escape")
        {
            _labelSearch = "";
            _labelDropdownOpen = false;
        }
    }

    private void OnLabelBlur()
    {
        // Small delay handled by @onmousedown on dropdown items
        _labelDropdownOpen = false;
    }

    // ── Label manager popup ──
    private void StartEditLabel(Label label)
    {
        _editingLabelId = label.Id;
        _editLabelName = label.Name;
        _editLabelColor = label.Color;
    }

    private async Task SaveLabel(int labelId)
    {
        if (string.IsNullOrWhiteSpace(_editLabelName)) return;
        await LabelService.UpdateLabelAsync(Slug, labelId, _editLabelName.Trim(), _editLabelColor);
        _editingLabelId = null;
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        if (_selectedTicket is not null)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        await RefreshTicketsAndTouch();
    }

    private async Task DeleteManagedLabel(int labelId)
    {
        await LabelService.DeleteLabelAsync(Slug, labelId);
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        if (_selectedTicket is not null)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, _selectedTicket.Id);
        await RefreshTicketsAndTouch();
    }

    private async Task CreateManagedLabel()
    {
        if (string.IsNullOrWhiteSpace(_managerNewName)) return;
        await LabelService.CreateLabelAsync(Slug, _managerNewName.Trim(), _managerNewColor);
        _allLabels = await LabelService.ListLabelsAsync(Slug);
        _managerNewName = "";
        _managerNewColor = "#6366f1";
    }

    // ── Assignee autocomplete ──
    private List<Member> GetAssigneeSuggestions()
    {
        var query = _assigneeSearch?.Trim() ?? "";
        return _allMembers
            .Where(m => string.IsNullOrEmpty(query)
                || m.Name.Contains(query, StringComparison.OrdinalIgnoreCase)
                || m.Slug.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private string MemberDisplayName(string? slug)
    {
        if (string.IsNullOrEmpty(slug)) return "";
        var member = _allMembers.FirstOrDefault(m => m.Slug == slug);
        return member?.Name ?? slug;
    }

    private async Task SetAssignee(string slug)
    {
        if (_selectedTicket is null) return;
        var oldAssignee = _selectedTicket.AssignedTo ?? "";
        var ticketId = _selectedTicket.Id;
        await TicketService.UpdateTicketAsync(Slug, ticketId, assignedTo: slug);
        PushUndo($"{L["UndoAssign"]} #{ticketId}", async () =>
            await TicketService.UpdateTicketAsync(Slug, ticketId, assignedTo: oldAssignee));
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
        _assigneeSearch = "";
        _assigneeDropdownOpen = false;
    }

    private async Task RemoveAssignee()
    {
        if (_selectedTicket is null) return;
        var oldAssignee = _selectedTicket.AssignedTo ?? "";
        var ticketId = _selectedTicket.Id;
        await TicketService.UpdateTicketAsync(Slug, ticketId, assignedTo: "");
        PushUndo($"{L["UndoUnassign"]} #{ticketId}", async () =>
            await TicketService.UpdateTicketAsync(Slug, ticketId, assignedTo: oldAssignee));
        _selectedTicket = await TicketService.GetTicketAsync(Slug, ticketId);
        await RefreshTicketsAndTouch();
    }

    private async Task CreateAndAssign()
    {
        if (_selectedTicket is null || string.IsNullOrWhiteSpace(_assigneeSearch)) return;
        var name = _assigneeSearch.Trim();
        var created = await MemberService.CreateMemberAsync(Slug, name);
        _allMembers = await MemberService.ListMembersAsync(Slug);
        await SetAssignee(created.Slug);
    }

    private async Task HandleAssigneeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_assigneeSearch))
        {
            var suggestions = GetAssigneeSuggestions();
            if (suggestions.Count > 0)
                await SetAssignee(suggestions[0].Slug);
            else
                await CreateAndAssign();
        }
        else if (e.Key == "Escape")
        {
            _assigneeSearch = "";
            _assigneeDropdownOpen = false;
        }
    }

    private void OnAssigneeBlur()
    {
        _assigneeDropdownOpen = false;
    }

    // ── Member manager popup ──
    private void StartEditMember(Member member)
    {
        _editingMemberId = member.Id;
        _editMemberName = member.Name;
    }

    private async Task SaveMember(int memberId)
    {
        if (string.IsNullOrWhiteSpace(_editMemberName)) return;
        await MemberService.UpdateMemberAsync(Slug, memberId, _editMemberName.Trim());
        _editingMemberId = null;
        _allMembers = await MemberService.ListMembersAsync(Slug);
    }

    private async Task DeleteManagedMember(int memberId)
    {
        await MemberService.DeleteMemberAsync(Slug, memberId);
        _allMembers = await MemberService.ListMembersAsync(Slug);
    }

    private async Task CreateManagedMember()
    {
        if (string.IsNullOrWhiteSpace(_managerNewMemberName)) return;
        await MemberService.CreateMemberAsync(Slug, _managerNewMemberName.Trim());
        _allMembers = await MemberService.ListMembersAsync(Slug);
        _managerNewMemberName = "";
    }
