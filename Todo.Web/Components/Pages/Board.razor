@page "/board/{Slug}"
@page "/board/{Slug}/ticket/{TicketId:int}"
@using Markdig
@using Microsoft.AspNetCore.Components
@using Todo.Core.Models
@using Todo.Core.Services
@using Todo.Web.Extensions
@inject ProjectService ProjectService
@inject TicketService TicketService
@inject LabelService LabelService
@inject ColumnService ColumnService
@inject MemberService MemberService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(_project?.Name ?? "Board")</PageTitle>

@if (_project is null)
{
    <p>Projet introuvable.</p>
}
else
{
    <div class="page-header">
        <a href="/" class="back-link">&larr; Projets</a>
        <h1>@_project.Name</h1>
        <div class="header-right">
            @if (_showAddColumn)
            {
                <div class="add-column-form">
                    <input @bind="_newColumnName" @bind:event="oninput" placeholder="Nom de la colonne..." />
                    <input type="color" @bind="_newColumnColor" />
                    <button class="icon-btn save-btn" @onclick="AddColumn" disabled="@string.IsNullOrWhiteSpace(_newColumnName)">&#10003;</button>
                    <button class="icon-btn cancel-icon-btn" @onclick="() => _showAddColumn = false">&#10005;</button>
                </div>
            }
            else
            {
                <button class="header-action-btn" @onclick="() => _showAddColumn = true">+ Colonne</button>
            }
            <button class="header-action-btn" @onclick="() => _showLabelManager = true" title="Gérer les labels">&#127991; Labels</button>
            <button class="header-action-btn" @onclick="() => _showMemberManager = true" title="Gérer les membres">&#128101; Membres</button>
        </div>
    </div>

    <div class="board">
        @foreach (var col in _columns)
        {
            var colIndex = _columns.IndexOf(col);
            <div class="column @(_draggedColumn?.Id == col.Id ? "column-dragging" : "")"
                 style="--col-color: @col.Color"
                 @ondragover="(e) => OnDragOverColumn(col.Name, e)"
                 @ondragover:preventDefault
                 @ondrop="() => OnDrop(col.Name)"
                 @ondrop:preventDefault>
                @if (_draggedColumn is not null && _draggedTicket is null && _colDropIndex == colIndex && _draggedColumn.Id != col.Id)
                {
                    <div class="column-drop-indicator"></div>
                }
                <div class="column-header"
                     draggable="true"
                     @ondragstart="() => OnColumnDragStart(col)"
                     @ondragend="OnColumnDragEnd"
                     @ondragover="(e) => OnColumnDragOver(colIndex, e)"
                     @ondragover:preventDefault
                     @ondrop="OnColumnDrop"
                     @ondrop:preventDefault>
                    <span class="status-pill" style="color: @col.Color; background: color-mix(in srgb, @col.Color 12%, transparent)">@col.Name</span>
                    <span class="count">@GetTickets(col.Name).Count</span>
                </div>
                <div class="column-body">
                    @{ var columnTickets = GetTickets(col.Name); }
                    @for (int i = 0; i < columnTickets.Count; i++)
                    {
                        var ticket = columnTickets[i];
                        var index = i;
                        @if (_dragOverStatus == col.Name && _dragInsertIndex == index && _draggedTicket is not null && _draggedTicket.Id != ticket.Id)
                        {
                            <div class="drop-indicator"></div>
                        }
                        <div class="ticket-card @(_selectedTicket?.Id == ticket.Id ? "selected" : "") @(_draggedTicket?.Id == ticket.Id ? "dragging" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStart(ticket)"
                             @ondragend="OnDragEnd"
                             @ondragover="(e) => OnDragOverCard(col.Name, index, e)"
                             @ondragover:preventDefault
                             @onclick="() => SelectTicket(ticket)">
                            <div class="ticket-card-top">
                                <span class="priority-dot priority-@GetPriorityClass(ticket.Priority)" title="@GetPriorityLabel(ticket.Priority)"></span>
                                <span class="ticket-id">#@ticket.Id</span>
                            </div>
                            <span class="ticket-title">@ticket.Title</span>
                            @if (ticket.Labels.Count > 0)
                            {
                                <div class="label-list">
                                    @foreach (var label in ticket.Labels)
                                    {
                                        <span class="label-pill" style="--lc: @label.Color">@label.Name</span>
                                    }
                                </div>
                            }
                            <div class="ticket-card-bottom">
                                @if (!string.IsNullOrEmpty(ticket.AssignedTo))
                                {
                                    <span class="assignee-badge" title="@ticket.AssignedTo">@ticket.AssignedTo</span>
                                }
                                <small class="ticket-author">@ticket.CreatedBy</small>
                            </div>
                        </div>
                    }
                    @if (_dragOverStatus == col.Name && _dragInsertIndex >= columnTickets.Count && _draggedTicket is not null)
                    {
                        <div class="drop-indicator"></div>
                    }
                </div>
                @if (col == _columns[0])
                {
                    <div class="add-ticket">
                        <button class="add-ticket-btn" @onclick="OpenCreatePopup">+ Nouveau ticket</button>
                    </div>
                }
            </div>
        }

    </div>

    @* ── Trash drop zone (visible during drag) ── *@
    @if (_draggedTicket is not null || _draggedColumn is not null)
    {
        <div class="trash-zone @(_trashHover ? "trash-zone-hover" : "")"
             @ondragover="OnTrashDragOver"
             @ondragover:preventDefault
             @ondragleave="() => _trashHover = false"
             @ondrop="OnTrashDrop"
             @ondrop:preventDefault>
            <span class="trash-icon">&#128465;</span>
            <span>Supprimer</span>
        </div>
    }

    @* ── Trash confirmation dialog ── *@
    @if (_trashConfirmColumn is not null)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>Supprimer la colonne «&#160;@_trashConfirmColumn.Name&#160;»&#160;?</p>
                @if (_columns.Count > 1)
                {
                    <p class="confirm-warning">Les tickets seront déplacés vers&#160;:</p>
                    <select @bind="_deleteColumnMoveTo" style="margin-bottom:0.5rem;width:100%">
                        @foreach (var other in _columns.Where(c => c.Id != _trashConfirmColumn.Id))
                        {
                            <option value="@other.Name">@other.Name</option>
                        }
                    </select>
                }
                <div class="confirm-actions">
                    <button class="cancel-btn" @onclick="CancelTrash">Annuler</button>
                    <button class="delete-btn" @onclick="ConfirmTrashColumn">Supprimer</button>
                </div>
            </div>
        </div>
    }
    @if (_trashConfirmTicket is not null)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>Supprimer le ticket #@_trashConfirmTicket.Id «&#160;@_trashConfirmTicket.Title&#160;»&#160;?</p>
                <div class="confirm-actions">
                    <button class="cancel-btn" @onclick="CancelTrash">Annuler</button>
                    <button class="delete-btn" @onclick="ConfirmTrashTicket">Supprimer</button>
                </div>
            </div>
        </div>
    }

    @* ── Create ticket popup ── *@
    @if (_showCreatePopup)
    {
        <div class="ticket-modal-overlay" @onmousedown="CloseCreatePopup">
            <div class="create-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>Nouveau ticket</h2>
                    <button class="close-btn" @onclick="CloseCreatePopup">&times;</button>
                </div>
                <div class="create-popup-body">
                    <label class="field-label">Titre</label>
                    <input class="create-input" @bind="_newTicketTitle" @bind:event="oninput" placeholder="Titre du ticket..." />

                    <label class="field-label">Description <span class="field-hint">(Markdown)</span></label>
                    <textarea class="create-textarea" @bind="_newTicketDescription" placeholder="Description..."></textarea>

                    <label class="field-label">Priorit&#233;</label>
                    <div class="priority-picker">
                        @foreach (var p in Enum.GetValues<TicketPriority>())
                        {
                            <button class="priority-option @(_newTicketPriority == p ? "active" : "")"
                                    @onclick="() => _newTicketPriority = p">
                                <span class="priority-dot priority-@GetPriorityClass(p)"></span>
                                @GetPriorityLabel(p)
                            </button>
                        }
                    </div>

                    <label class="field-label">Labels</label>
                    <div class="label-picker">
                        @foreach (var label in _allLabels)
                        {
                            var selected = _newTicketLabelIds.Contains(label.Id);
                            <button class="label-toggle @(selected ? "active" : "")"
                                    style="--lc: @label.Color"
                                    @onclick="() => ToggleLabel(label.Id)">
                                @label.Name
                            </button>
                        }
                        @if (_showNewLabelForm)
                        {
                            <div class="new-label-form">
                                <input @bind="_newLabelName" placeholder="Nom du label" />
                                <input type="color" @bind="_newLabelColor" />
                                <button class="save-btn icon-btn" @onclick="CreateLabel">&#10003;</button>
                                <button class="cancel-icon-btn icon-btn" @onclick="() => _showNewLabelForm = false">&#10005;</button>
                            </div>
                        }
                        else
                        {
                            <button class="label-add-btn" @onclick="() => _showNewLabelForm = true">+ Label</button>
                        }
                    </div>

                    <label class="field-label">Assigner à</label>
                    <div class="assignee-picker-wrapper">
                        <select class="assignee-select" @bind="_newTicketAssignedTo">
                            <option value="">— Non assigné —</option>
                            @foreach (var member in _allMembers)
                            {
                                <option value="@member.Name">@member.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="create-popup-footer">
                    <button class="cancel-btn" @onclick="CloseCreatePopup">Annuler</button>
                    <button @onclick="CreateTicket" disabled="@string.IsNullOrWhiteSpace(_newTicketTitle)">Cr&#233;er le ticket</button>
                </div>
            </div>
        </div>
    }

    @if (_selectedTicket is not null)
    {
        <div class="ticket-modal-overlay" @onmousedown="ClosePanel">
            <div class="ticket-panel" @onmousedown:stopPropagation>
            <div class="ticket-panel-header">
                <div class="editable-field">
                    <div class="priority-dot-btn" @onclick="() => _showPriorityPicker = !_showPriorityPicker" title="Changer la priorité">
                        <span class="priority-dot priority-@GetPriorityClass(_selectedTicket.Priority)"></span>
                    </div>
                    @if (_showPriorityPicker)
                    {
                        <div class="priority-dropdown">
                            @foreach (var p in Enum.GetValues<TicketPriority>())
                            {
                                <button class="priority-option @(_selectedTicket.Priority == p ? "active" : "")"
                                        @onclick="() => SetPriorityAndClose(p)">
                                    <span class="priority-dot priority-@GetPriorityClass(p)"></span>
                                    @GetPriorityLabel(p)
                                </button>
                            }
                        </div>
                    }
                    @if (_editingTitle)
                    {
                        <span class="ticket-id-prefix">#@_selectedTicket.Id &mdash;</span>
                        <input class="edit-title-input" @bind="_editTitle" @onkeydown="HandleTitleKeyDown" />
                        <button class="icon-btn save-btn" title="Enregistrer" @onclick="SaveTitle">&#10003;</button>
                        <button class="icon-btn cancel-icon-btn" title="Annuler" @onclick="() => _editingTitle = false">&#10005;</button>
                    }
                    else
                    {
                        <h2>#@_selectedTicket.Id &mdash; @_selectedTicket.Title</h2>
                        <button class="icon-btn pencil-btn" title="Modifier le titre" @onclick="StartEditTitle">&#9998;</button>
                    }
                </div>
                <div class="header-actions">
                    <button class="close-btn" @onclick="ClosePanel">&times;</button>
                </div>
            </div>

            @* ── Labels row ── *@
            <div class="ticket-labels-row">
                @foreach (var label in _selectedTicket.Labels)
                {
                    var lid = label.Id;
                    <span class="label-pill label-removable" style="--lc: @label.Color">
                        @label.Name
                        <button class="label-remove-btn" @onclick="() => RemoveLabel(lid)">&times;</button>
                    </span>
                }
                <div class="label-autocomplete">
                    <input class="label-autocomplete-input"
                           placeholder="+ Label..."
                           @bind="_labelSearch"
                           @bind:event="oninput"
                           @onfocus="() => _labelDropdownOpen = true"
                           @onblur="OnLabelBlur"
                           @onkeydown="HandleLabelKeyDown" />
                    @if (_labelDropdownOpen && GetLabelSuggestions().Any())
                    {
                        <div class="label-dropdown">
                            @foreach (var suggestion in GetLabelSuggestions())
                            {
                                <button class="label-dropdown-item" style="--lc: @suggestion.Color"
                                        @onmousedown="() => AddExistingLabel(suggestion)">
                                    <span class="label-pill" style="--lc: @suggestion.Color">@suggestion.Name</span>
                                </button>
                            }
                        </div>
                    }
                    @if (_labelDropdownOpen && !string.IsNullOrWhiteSpace(_labelSearch) && !_allLabels.Any(l => l.Name.Equals(_labelSearch.Trim(), StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="label-dropdown @(GetLabelSuggestions().Any() ? "" : "label-dropdown-only")">
                            <button class="label-dropdown-item label-create-item" @onmousedown="CreateAndAddLabel">
                                Créer «&#160;@_labelSearch.Trim()&#160;»
                            </button>
                        </div>
                    }
                </div>
            </div>

            @* ── Assignee row ── *@
            <div class="ticket-assignee-row">
                <span class="section-label-sm">Assigné à&#160;:</span>
                @if (!string.IsNullOrEmpty(_selectedTicket.AssignedTo))
                {
                    <span class="assignee-pill">
                        @_selectedTicket.AssignedTo
                        <button class="label-remove-btn" @onclick="RemoveAssignee">&times;</button>
                    </span>
                }
                <div class="label-autocomplete">
                    <input class="label-autocomplete-input"
                           placeholder="@(string.IsNullOrEmpty(_selectedTicket.AssignedTo) ? "+ Assigner..." : "Changer...")"
                           @bind="_assigneeSearch"
                           @bind:event="oninput"
                           @onfocus="() => _assigneeDropdownOpen = true"
                           @onblur="OnAssigneeBlur"
                           @onkeydown="HandleAssigneeKeyDown" />
                    @if (_assigneeDropdownOpen && GetAssigneeSuggestions().Any())
                    {
                        <div class="label-dropdown">
                            @foreach (var member in GetAssigneeSuggestions())
                            {
                                <button class="label-dropdown-item" @onmousedown="() => SetAssignee(member.Name)">
                                    <span class="assignee-pill">@member.Name</span>
                                </button>
                            }
                        </div>
                    }
                    @if (_assigneeDropdownOpen && !string.IsNullOrWhiteSpace(_assigneeSearch) && !_allMembers.Any(m => m.Name.Equals(_assigneeSearch.Trim(), StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="label-dropdown @(GetAssigneeSuggestions().Any() ? "" : "label-dropdown-only")">
                            <button class="label-dropdown-item label-create-item" @onmousedown="CreateAndAssign">
                                Créer «&#160;@_assigneeSearch.Trim()&#160;»
                            </button>
                        </div>
                    }
                </div>
            </div>

            @* ── Two-column body ── *@
            <div class="ticket-panel-columns">
                <div class="ticket-col-left">
                    <div class="section-header">
                        <span class="section-label">Description</span>
                        @if (!_editingDescription)
                        {
                            <button class="icon-btn pencil-btn" title="Modifier la description" @onclick="StartEditDescription">&#9998;</button>
                        }
                    </div>
                    @if (_editingDescription)
                    {
                        <textarea class="edit-textarea" @bind="_editDescription"></textarea>
                        <div class="edit-actions">
                            <button @onclick="SaveDescription">Enregistrer</button>
                            <button class="cancel-btn" @onclick="() => _editingDescription = false">Annuler</button>
                        </div>
                    }
                    else
                    {
                        <div class="ticket-desc markdown">
                            @if (_selectedTicket.Description is { Length: > 0 })
                            {
                                @((MarkupString)Markdown.ToHtml(_selectedTicket.Description, _mdPipeline))
                            }
                            else
                            {
                                <p class="empty-hint">Aucune description &mdash; cliquez sur &#9998; pour en ajouter une.</p>
                            }
                        </div>
                    }

                    <div class="ticket-meta">
                        <span>Statut&#160;: <strong>@_selectedTicket.Status</strong></span>
                        <span>Par&#160;: @_selectedTicket.CreatedBy</span>
                        <span>Créé&#160;: @_selectedTicket.CreatedAt.ToString("g")</span>
                    </div>

                    <div class="panel-footer-actions">
                        @if (_confirmDelete)
                        {
                            <span class="confirm-delete-label">Supprimer ce ticket&#160;?</span>
                            <button class="delete-btn" @onclick="DeleteSelectedTicket">Confirmer</button>
                            <button class="cancel-btn" @onclick="() => _confirmDelete = false">Annuler</button>
                        }
                        else
                        {
                            <button class="delete-btn" @onclick="() => _confirmDelete = true">Supprimer ce ticket</button>
                        }
                    </div>
                </div>

                <div class="ticket-col-right">
                    <div class="activity-header">
                        <span class="section-label">Activité</span>
                        @if (!_addingComment)
                        {
                            <button class="add-comment-btn-sm" @onclick="() => _addingComment = true">+ Commentaire</button>
                        }
                    </div>
                    @if (_addingComment)
                    {
                        <div class="inline-comment-form">
                            <textarea class="edit-textarea" @bind="_newComment" placeholder="Écrire un commentaire..."></textarea>
                            <div class="edit-actions">
                                <button @onclick="AddComment" disabled="@string.IsNullOrWhiteSpace(_newComment)">Envoyer</button>
                                <button class="cancel-btn" @onclick="CancelComment">Annuler</button>
                            </div>
                        </div>
                    }
                    <div class="activity-scroll">
                        @foreach (var item in GetTimeline())
                        {
                            @if (item.IsComment)
                            {
                                <div class="timeline-comment">
                                    <div class="timeline-comment-header">
                                        <strong>@item.Author</strong>
                                        <small>@item.At.ToString("g")</small>
                                        @if (_editingCommentId != item.Id)
                                        {
                                            <button class="icon-btn pencil-btn" title="Modifier" @onclick="() => StartEditComment(item.Id!.Value, item.Text)">&#9998;</button>
                                        }
                                    </div>
                                    @if (_editingCommentId == item.Id)
                                    {
                                        <textarea class="edit-textarea" @bind="_editComment"></textarea>
                                        <div class="edit-actions">
                                            <button @onclick="SaveComment">Enregistrer</button>
                                            <button class="cancel-btn" @onclick="() => _editingCommentId = null">Annuler</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="markdown">@((MarkupString)Markdown.ToHtml(item.Text, _mdPipeline))</div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="timeline-event">
                                    <span class="event-dot"></span>
                                    <div class="event-content">
                                        <span class="event-author">@item.Author</span>
                                        <span class="event-text">@item.Text</span>
                                        <small>@item.At.ToString("g")</small>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            </div>
        </div>
    }

    @* ── Label management popup ── *@
    @if (_showLabelManager)
    {
        <div class="ticket-modal-overlay" @onmousedown="() => _showLabelManager = false">
            <div class="label-manager-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>Gestion des labels</h2>
                    <button class="close-btn" @onclick="() => _showLabelManager = false">&times;</button>
                </div>
                <div class="label-manager-body">
                    @foreach (var label in _allLabels)
                    {
                        var lid = label.Id;
                        <div class="label-manager-row">
                            @if (_editingLabelId == lid)
                            {
                                <input class="label-manager-name" @bind="_editLabelName" placeholder="Nom..." />
                                <input type="color" class="label-manager-color" @bind="_editLabelColor" />
                                <button class="icon-btn save-btn" @onclick="() => SaveLabel(lid)">&#10003;</button>
                                <button class="icon-btn cancel-icon-btn" @onclick="() => _editingLabelId = null">&#10005;</button>
                            }
                            else
                            {
                                <span class="label-pill" style="--lc: @label.Color">@label.Name</span>
                                <button class="icon-btn pencil-btn" @onclick="() => StartEditLabel(label)">&#9998;</button>
                                <button class="icon-btn label-delete-icon" @onclick="() => DeleteManagedLabel(lid)">&times;</button>
                            }
                        </div>
                    }
                    <div class="label-manager-add">
                        <input @bind="_managerNewName" placeholder="Nouveau label..." />
                        <input type="color" @bind="_managerNewColor" />
                        <button class="icon-btn save-btn" @onclick="CreateManagedLabel" disabled="@string.IsNullOrWhiteSpace(_managerNewName)">&#10003;</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Member management popup ── *@
    @if (_showMemberManager)
    {
        <div class="ticket-modal-overlay" @onmousedown="() => _showMemberManager = false">
            <div class="label-manager-popup" @onmousedown:stopPropagation>
                <div class="create-popup-header">
                    <h2>Gestion des membres</h2>
                    <button class="close-btn" @onclick="() => _showMemberManager = false">&times;</button>
                </div>
                <div class="label-manager-body">
                    @foreach (var member in _allMembers)
                    {
                        var mid = member.Id;
                        <div class="label-manager-row">
                            @if (_editingMemberId == mid)
                            {
                                <input class="label-manager-name" @bind="_editMemberName" placeholder="Nom..." />
                                <button class="icon-btn save-btn" @onclick="() => SaveMember(mid)">&#10003;</button>
                                <button class="icon-btn cancel-icon-btn" @onclick="() => _editingMemberId = null">&#10005;</button>
                            }
                            else
                            {
                                <span class="assignee-pill">@member.Name</span>
                                <button class="icon-btn pencil-btn" @onclick="() => StartEditMember(member)">&#9998;</button>
                                <button class="icon-btn label-delete-icon" @onclick="() => DeleteManagedMember(mid)">&times;</button>
                            }
                        </div>
                    }
                    <div class="label-manager-add">
                        <input @bind="_managerNewMemberName" placeholder="Nouveau membre..." />
                        <button class="icon-btn save-btn" @onclick="CreateManagedMember" disabled="@string.IsNullOrWhiteSpace(_managerNewMemberName)">&#10003;</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Parameter] public int? TicketId { get; set; }

    private Project? _project;
    private List<Ticket> _tickets = [];
    private List<BoardColumn> _columns = [];
    private Ticket? _selectedTicket;
    private Ticket? _draggedTicket;
    private string? _dragOverStatus;
    private int _dragInsertIndex = -1;

    // Column drag & drop
    private BoardColumn? _draggedColumn;
    private int _colDropIndex = -1;
    private string _newComment = "";
    private bool _confirmDelete = false;

    // Create popup
    private bool _showCreatePopup = false;
    private string _newTicketTitle = "";
    private string _newTicketDescription = "";
    private List<int> _newTicketLabelIds = [];
    private TicketPriority _newTicketPriority = TicketPriority.NiceToHave;
    private List<Label> _allLabels = [];
    private bool _showNewLabelForm = false;
    private string _newLabelName = "";
    private string _newLabelColor = "#6366f1";

    // Column management
    private bool _showAddColumn = false;
    private string _newColumnName = "";
    private string _newColumnColor = "#5a6a80";
    private string _deleteColumnMoveTo = "";

    // Trash drop zone
    private bool _trashHover = false;
    private BoardColumn? _trashConfirmColumn = null;
    private Ticket? _trashConfirmTicket = null;

    // Inline editing state
    private bool _editingTitle = false;
    private string _editTitle = "";
    private bool _editingDescription = false;
    private string _editDescription = "";
    private int? _editingCommentId = null;
    private string _editComment = "";

    // Priority picker
    private bool _showPriorityPicker = false;

    // Label autocomplete
    private string _labelSearch = "";
    private bool _labelDropdownOpen = false;

    // Label manager popup
    private bool _showLabelManager = false;
    private int? _editingLabelId = null;
    private string _editLabelName = "";
    private string _editLabelColor = "#6366f1";
    private string _managerNewName = "";
    private string _managerNewColor = "#6366f1";

    // Members
    private List<Member> _allMembers = [];
    private string _newTicketAssignedTo = "";

    // Assignee autocomplete
    private string _assigneeSearch = "";
    private bool _assigneeDropdownOpen = false;

    // Member manager popup
    private bool _showMemberManager = false;
    private int? _editingMemberId = null;
    private string _editMemberName = "";
    private string _managerNewMemberName = "";

    // Inline comment
    private bool _addingComment = false;

    private MarkdownPipeline _mdPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private void RebuildPipeline()
    {
        var index = _tickets.ToDictionary(t => t.Id, t => t.Title);
        var memberHandles = new HashSet<string>(_allMembers.Select(m => MentionExtension.Slugify(m.Name)), StringComparer.OrdinalIgnoreCase);
        _mdPipeline = new MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .Use(new TicketReferenceExtension(Slug, index))
            .Use(new MentionExtension(memberHandles))
            .Build();
    }

    private record TimelineItem(DateTime At, string Author, bool IsComment, string Text, int? Id);

    private IEnumerable<TimelineItem> GetTimeline()
    {
        if (_selectedTicket is null) return [];
        return _selectedTicket.Comments
            .Select(c => new TimelineItem(c.CreatedAt, c.Author, true, c.Content, c.Id))
            .Concat(_selectedTicket.Activities
                .Select(a => new TimelineItem(a.CreatedAt, a.Author, false, a.Text, null)))
            .OrderByDescending(x => x.At);
    }

    protected override async Task OnInitializedAsync()
    {
        _project = await ProjectService.GetProjectAsync(Slug);
        if (_project is not null)
        {
            _columns = await ColumnService.ListColumnsAsync(Slug);
            _tickets = await TicketService.ListTicketsAsync(Slug);
            _allLabels = await LabelService.ListLabelsAsync(Slug);
            _allMembers = await MemberService.ListMembersAsync(Slug);
            RebuildPipeline();
        }
        if (TicketId.HasValue)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, TicketId.Value);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_project is null) return; // handled by OnInitializedAsync
        if (TicketId.HasValue && _selectedTicket?.Id != TicketId)
            _selectedTicket = await TicketService.GetTicketAsync(Slug, TicketId.Value);
        else if (!TicketId.HasValue && _selectedTicket is not null)
            _selectedTicket = null;
    }

    private List<Ticket> GetTickets(string status) =>
        _tickets.Where(t => t.Status == status).ToList();

    private static string GetPriorityLabel(TicketPriority p) => p switch
    {
        TicketPriority.Idea => "Idea",
        TicketPriority.NiceToHave => "Nice to have",
        TicketPriority.Required => "Required",
        TicketPriority.Critical => "Critical",
        _ => p.ToString()
    };

    private static string GetPriorityClass(TicketPriority p) => p switch
    {
        TicketPriority.Idea => "idea",
        TicketPriority.NiceToHave => "nice",
        TicketPriority.Required => "required",
        TicketPriority.Critical => "critical",
