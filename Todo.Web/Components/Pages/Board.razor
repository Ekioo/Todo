    private void OnDragStart(Ticket ticket) => _draggedTicket = ticket;

    private void OnDragEnd()
    {
        _draggedTicket = null;
        _dragOverStatus = null;
        _dragInsertIndex = -1;
        _trashHover = false;
    }

    // Column drag handlers
    private void OnColumnDragStart(BoardColumn col) => _draggedColumn = col;

    private void OnColumnDragEnd()
    {
        _draggedColumn = null;
        _colDropIndex = -1;
        _trashHover = false;
    }

    private void OnColumnDragOver(int colIndex, DragEventArgs e)
    {
        if (_draggedColumn is null) return;
        _colDropIndex = e.OffsetX < 115 ? colIndex : colIndex + 1;
    }

    private async Task OnColumnDrop()
    {
        if (_draggedColumn is null) return;

        var targetIndex = _colDropIndex >= 0 ? _colDropIndex : _columns.Count;
        var currentIndex = _columns.FindIndex(c => c.Id == _draggedColumn.Id);
        if (currentIndex >= 0 && currentIndex < targetIndex)
            targetIndex--;

        await ColumnService.ReorderColumnAsync(Slug, _draggedColumn.Id, targetIndex);
        _columns = await ColumnService.ListColumnsAsync(Slug);
        _draggedColumn = null;
        _colDropIndex = -1;
    }

    private void OnDragOverCard(string status, int cardIndex, DragEventArgs e)
    {
        if (_draggedTicket is null) return;
        _dragOverStatus = status;
        // Use hysteresis: only flip insertion side when clearly past threshold,
        // keep current side inside the dead zone to prevent oscillation.
        var newIndex = e.OffsetY < 30 ? cardIndex : e.OffsetY > 50 ? cardIndex + 1 : _dragInsertIndex;
        _dragInsertIndex = (newIndex >= 0) ? newIndex : cardIndex;
    }

    private void OnDragOverColumn(string status, DragEventArgs e)
    {
        if (_draggedTicket is null) return;
        _dragOverStatus = status;
        var count = GetTickets(status).Count;
        if (_dragInsertIndex < 0 || _dragOverStatus != status)
            _dragInsertIndex = count;
    }

    private async Task OnDrop(string newStatus)
    {
        if (_draggedTicket is null) return;

        var targetIndex = _dragInsertIndex >= 0 ? _dragInsertIndex : GetTickets(newStatus).Count;

        // If dropping in the same column, adjust index for the dragged item's removal
        if (_draggedTicket.Status == newStatus)
        {
            var currentIndex = GetTickets(newStatus).IndexOf(_draggedTicket);
            if (currentIndex >= 0 && currentIndex < targetIndex)
                targetIndex--;
        }

        await TicketService.ReorderTicketAsync(Slug, _draggedTicket.Id, newStatus, targetIndex);
        _tickets = await TicketService.ListTicketsAsync(Slug);
        _draggedTicket = null;
        _dragOverStatus = null;
        _dragInsertIndex = -1;
        RebuildPipeline();
    }

