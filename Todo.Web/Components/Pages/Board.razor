        var name = _assigneeSearch.Trim();
        await MemberService.CreateMemberAsync(Slug, name);
        _allMembers = await MemberService.ListMembersAsync(Slug);
        await SetAssignee(name);
    }

    private async Task HandleAssigneeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_assigneeSearch))
        {
            var suggestions = GetAssigneeSuggestions();
            if (suggestions.Count > 0)
                await SetAssignee(suggestions[0].Name);
            else
                await CreateAndAssign();
        }
        else if (e.Key == "Escape")
        {
            _assigneeSearch = "";
            _assigneeDropdownOpen = false;
        }
    }

    private void OnAssigneeBlur()
