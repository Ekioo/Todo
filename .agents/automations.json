{
  "automations": [
    {
      "id": "assignee-dispatch",
      "name": "Dispatch: ticket Todo -> InProgress + lance agent assigne",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "Todo"
        ],
        "debounceSeconds": 0
      },
      "conditions": [
        {
          "type": "noPendingTickets",
          "columns": [
            "InProgress"
          ],
          "sameAssignee": true
        }
      ],
      "actions": [
        {
          "type": "moveTicketStatus",
          "to": "InProgress"
        },
        {
          "type": "runAgent",
          "agent": "{assignee}",
          "concurrencyGroup": "{assignee}",
          "maxTurns": 100,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "{assignee}"
        }
      ]
    },
    {
      "id": "groomer",
      "name": "Groomer: enrichir tickets Backlog assignes au groomer",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "Backlog"
        ],
        "assigneeSlug": "groomer",
        "debounceSeconds": 0
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "groomer",
          "maxTurns": 100,
          "concurrencyGroup": "groomer",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-haiku-4-5",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "groomer"
        }
      ]
    },
    {
      "id": "committer-on-done",
      "name": "Committer — commit quand un ticket passe à Done",
      "enabled": true,
      "trigger": {
        "type": "statusChange",
        "pollSeconds": 30,
        "to": "Done"
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "committer",
          "maxTurns": 50,
          "concurrencyGroup": "committer",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-haiku-4-5",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "committer"
        }
      ]
    },
    {
      "id": "producer-on-subtick",
      "name": "Producer — re-dispatch quand sous-tickets changent",
      "enabled": true,
      "trigger": {
        "type": "subTicketStatus",
        "pollSeconds": 30
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "producer",
          "maxTurns": 50,
          "concurrencyGroup": "producer",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "producer"
        }
      ]
    },
    {
      "id": "evaluator-on-done",
      "name": "Evaluator — vérifier les tickets passés à Done",
      "enabled": true,
      "trigger": {
        "type": "statusChange",
        "pollSeconds": 30,
        "to": "Done"
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "evaluator",
          "maxTurns": 50,
          "concurrencyGroup": "evaluator",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "evaluator"
        }
      ]
    },
    {
      "id": "code-janitor-nightly",
      "name": "Code Janitor — nettoyage périodique du codebase",
      "enabled": true,
      "trigger": {
        "type": "interval",
        "seconds": 10800
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "code-janitor",
          "maxTurns": 150,
          "concurrencyGroup": "code-janitor",
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-haiku-4-5",
          "restoreStatusOnFail": true
        },
        {
          "type": "commitAgentMemory",
          "agent": "code-janitor"
        }
      ]
    },
    {
      "id": "auto-review-on-all-subs-done",
      "name": "Passer parent en Review quand tous les sous-tickets sont Done",
      "enabled": true,
      "trigger": {
        "type": "subTicketStatus",
        "pollSeconds": 30,
        "parentColumn": "InProgress"
      },
      "conditions": [
        {
          "type": "allSubTicketsInStatus",
          "statuses": [
            "Done"
          ],
          "negate": false
        }
      ],
      "actions": [
        {
          "type": "moveTicketStatus",
          "to": "Review"
        },
        {
          "type": "addComment",
          "content": "Tous les sous-tickets sont en Done. Parent deplace en Review automatiquement.",
          "author": "system"
        }
      ]
    },
    {
      "id": "programmer-run",
      "name": "Programmer: resume sur ticket InProgress",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 30,
        "columns": [
          "InProgress"
        ],
        "assigneeSlug": "programmer",
        "debounceSeconds": 0
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "programmer",
          "concurrencyGroup": "programmer",
          "maxTurns": 200,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": false
        },
        {
          "type": "commitAgentMemory",
          "agent": "programmer"
        }
      ]
    },
    {
      "id": "qa-tester-run",
      "name": "QA tester: resume sur ticket InProgress",
      "enabled": true,
      "trigger": {
        "type": "ticketInColumn",
        "seconds": 60,
        "columns": [
          "InProgress"
        ],
        "assigneeSlug": "qa-tester",
        "debounceSeconds": 0
      },
      "conditions": [],
      "actions": [
        {
          "type": "runAgent",
          "agent": "qa-tester",
          "concurrencyGroup": "qa-tester",
          "maxTurns": 100,
          "mutuallyExclusiveWith": [],
          "env": {},
          "model": "claude-sonnet-4-6",
          "restoreStatusOnFail": false
        },
        {
          "type": "commitAgentMemory",
          "agent": "qa-tester"
        }
      ]
    }
  ]
}